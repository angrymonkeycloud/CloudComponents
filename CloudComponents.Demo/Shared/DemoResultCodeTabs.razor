@*
    Result / Code tab switcher. The Result pane stays mounted while hidden
    so switching tabs never tears down the live component state.
*@
<div class="demo-tabs">
    <div class="demo-tabs-strip">
        <button type="button" class="demo-tab @(_active == Tab.Result ? "active" : "")"
                @onclick="@(() => _active = Tab.Result)">
            @ResultLabel
        </button>
        <button type="button" class="demo-tab @(_active == Tab.Code ? "active" : "")"
                @onclick="@(() => _active = Tab.Code)">
            @CodeLabel
        </button>
    </div>

    <div class="demo-tabs-panel" style="@(_active == Tab.Result ? "" : "display:none;")">
        @ResultContent
    </div>

    <div class="demo-tabs-panel" style="@(_active == Tab.Code ? "" : "display:none;")">
        @CodeContent
    </div>
</div>

@code {
    private enum Tab { Result, Code }
    private Tab _active = Tab.Result;

    [Parameter] public RenderFragment? ResultContent { get; set; }
    [Parameter] public RenderFragment? CodeContent { get; set; }
    [Parameter] public string ResultLabel { get; set; } = "Result";
    [Parameter] public string CodeLabel { get; set; } = "Code";
}
