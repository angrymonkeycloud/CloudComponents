@page "/icons"
@inject IJSRuntime JS

<PageTitle>CloudIcons — Icons Browser</PageTitle>

<div class="page-header">
    <h1>Icons</h1>
    <p>Browse all 23 icons. Click any tile to inspect it in the detail panel, then download as <code>.svg</code> or copy the <code>.razor</code> usage snippet.</p>
</div>

<div class="controls-bar">
    <label>
        Size
        <input type="range" min="16" max="96" step="4" @bind="size" @bind:event="oninput" />
        <span class="value-badge">@size px</span>
    </label>
    <label>
        Color
        <input type="color" @bind="color" @bind:event="oninput" />
        <span class="value-badge">@color</span>
    </label>
    <label>
        Filter
        <input type="text" placeholder="Search icons…" @bind="filter" @bind:event="oninput" />
    </label>
</div>

<div class="browser-layout">
    <div>
        <div class="icon-grid">
            @foreach (var icon in FilteredIcons)
            {
                <div class="icon-tile @(selected == icon.Name ? "selected" : "")"
                     @onclick="() => selected = icon.Name">
                    <div class="icon-tile-svg" style="width:@(size)px;height:@(size)px;color:@color;">
                        @RenderIcon(icon.Name)
                    </div>
                    <span class="icon-tile-label">@icon.Name</span>
                </div>
            }
        </div>
        @if (!FilteredIcons.Any())
        {
            <p style="color:var(--text-secondary);margin-top:1rem;">No icons match &ldquo;@filter&rdquo;.</p>
        }
    </div>

    <div class="detail-panel">
        @if (SelectedIcon is { } si)
        {
            <h3>@si.Name</h3>
            <p class="detail-panel-subtitle">CloudIcons.Icons</p>
            <div class="detail-preview" id="icon-detail-preview">
                <div style="width:@(size)px;height:@(size)px;color:@color;">
                    @RenderIcon(si.Name)
                </div>
            </div>
            <pre class="code-snippet">@si.Snippet</pre>
            <div class="detail-actions" style="margin-top:0.75rem;">
                <button class="btn btn-primary" @onclick="DownloadSvg">Download .svg</button>
                <button class="btn" @onclick="DownloadRazor">Download .razor</button>
            </div>
        }
        else
        {
            <p style="color:var(--text-secondary);font-size:0.88rem;">Select an icon to inspect it.</p>
        }
    </div>
</div>

@code {
    private int size = 40;
    private string color = "#e0e0e0";
    private string filter = "";
    private string? selected;
    private IJSObjectReference? _downloadModule;

    private record IconDef(string Name, string Snippet);

    private static readonly List<IconDef> AllIcons =
    [
        new("AddIcon",            "<AddIcon />"),
        new("Cast",               "<Cast />"),
        new("Checkmark",          "<Checkmark />"),
        new("ChevronIcon",        "<ChevronIcon />"),
        new("Close",              "<Close />"),
        new("CloseIcon",          "<CloseIcon />"),
        new("CrossIcon",          "<CrossIcon />"),
        new("DragIcon",           "<DragIcon />"),
        new("ExitFullscreenIcon", "<ExitFullscreenIcon />"),
        new("ExpandIcon",         "<ExpandIcon />"),
        new("FullscreenIcon",     "<FullscreenIcon />"),
        new("Loading",            "<Loading />"),
        new("PauseButton",        "<PauseButton />"),
        new("PlayButton",         "<PlayButton />"),
        new("RefreshIcon",        "<RefreshIcon />"),
        new("ReorderIcon",        "<ReorderIcon />"),
        new("SaveIcon",           "<SaveIcon />"),
        new("SearchIcon",         "<SearchIcon />"),
        new("SettingsIcon",       "<SettingsIcon />"),
        new("SortIcon",           "<SortIcon />"),
        new("StopIcon",           "<StopIcon />"),
        new("Volume",             "<Volume />"),
        new("VolumeMute",         "<VolumeMute />"),
    ];

    private RenderFragment RenderIcon(string name) => name switch
    {
        "AddIcon"            => @<AddIcon />,
        "Cast"               => @<Cast />,
        "Checkmark"          => @<Checkmark />,
        "ChevronIcon"        => @<ChevronIcon />,
        "Close"              => @<Close />,
        "CloseIcon"          => @<CloseIcon />,
        "CrossIcon"          => @<CrossIcon />,
        "DragIcon"           => @<DragIcon />,
        "ExitFullscreenIcon" => @<ExitFullscreenIcon />,
        "ExpandIcon"         => @<ExpandIcon />,
        "FullscreenIcon"     => @<FullscreenIcon />,
        "Loading"            => @<Loading />,
        "PauseButton"        => @<PauseButton />,
        "PlayButton"         => @<PlayButton />,
        "RefreshIcon"        => @<RefreshIcon />,
        "ReorderIcon"        => @<ReorderIcon />,
        "SaveIcon"           => @<SaveIcon />,
        "SearchIcon"         => @<SearchIcon />,
        "SettingsIcon"       => @<SettingsIcon />,
        "SortIcon"           => @<SortIcon />,
        "StopIcon"           => @<StopIcon />,
        "Volume"             => @<Volume />,
        "VolumeMute"         => @<VolumeMute />,
        _                    => @<span></span>,
    };

    private IEnumerable<IconDef> FilteredIcons =>
        string.IsNullOrWhiteSpace(filter)
            ? AllIcons
            : AllIcons.Where(i => i.Name.Contains(filter, StringComparison.OrdinalIgnoreCase));

    private IconDef? SelectedIcon =>
        selected is not null ? AllIcons.FirstOrDefault(i => i.Name == selected) : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _downloadModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/download.js");
    }

    private async Task DownloadSvg()
    {
        if (_downloadModule is null || SelectedIcon is null) return;
        await _downloadModule.InvokeVoidAsync("downloadSvgFromElement",
            "icon-detail-preview", $"{SelectedIcon.Name}.svg", color, size);
    }

    private async Task DownloadRazor()
    {
        if (_downloadModule is null || SelectedIcon is null) return;
        var content = $"@using CloudIcons.Icons\n\n{SelectedIcon.Snippet}\n";
        await _downloadModule.InvokeVoidAsync("downloadText", $"{SelectedIcon.Name}.razor", content);
    }
}
