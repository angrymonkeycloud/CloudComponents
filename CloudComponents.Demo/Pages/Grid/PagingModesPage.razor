@page "/grid/paging"
@using AngryMonkey.CloudComponents.DataGrid
@using AngryMonkey.CloudComponents.DataGrid.Models
@using CloudComponents.Demo.Models
@using CloudComponents.Demo.Services
@using CloudComponents.Demo.Shared
@inject SampleDataService Data

<PageTitle>CloudDataGrid — Paging Modes</PageTitle>

<div class="page-header">
    <h1>Paging Modes</h1>
    <p>
        The same grid and data provider, switchable across all three paging modes. In
        <strong>Pages</strong> mode each page replaces the rows and the footer shows previous/next
        arrows. In <strong>Load more</strong> mode a button appends the next page. In
        <strong>Infinite scroll</strong> mode the next page loads automatically as you scroll near
        the end. The grid manages appending internally — the data provider just returns the
        requested page.
    </p>
</div>

<DemoResultCodeTabs>
    <ResultContent>
        <div class="card">
            <div class="toolbar">
                <label>Paging mode:</label>
                <div class="segmented">
                    <button class="@(_mode == CloudDataGridPagingMode.Pages ? "active" : "")"
                            @onclick="() => SetMode(CloudDataGridPagingMode.Pages)">Pages</button>
                    <button class="@(_mode == CloudDataGridPagingMode.LoadMore ? "active" : "")"
                            @onclick="() => SetMode(CloudDataGridPagingMode.LoadMore)">Load more</button>
                    <button class="@(_mode == CloudDataGridPagingMode.InfiniteScroll ? "active" : "")"
                            @onclick="() => SetMode(CloudDataGridPagingMode.InfiniteScroll)">Infinite scroll</button>
                </div>

                <label style="margin-left:1rem;">Rows per page:</label>
                <select class="input" @bind="_pageSize" @bind:after="ReloadGrid">
                    <option value="5">5</option>
                    <option value="8">8</option>
                    <option value="12">12</option>
                </select>

                <span class="badge">@_mode</span>
            </div>

            <div class="grid-host">
                <CloudDataGrid @key="_gridKey"
                           Columns="_columns"
                           DataProvider="LoadAsync"
                           PagingMode="_mode"
                           RowHeight="40"
                           RowsPerPage="_pageSize"
                           HeightMode="CloudDataGridHeightMode.RowHeight"
                           LoadMoreText="Load more employees" />
            </div>
        </div>
    </ResultContent>

    <CodeContent>
        <div class="card">
            <h2 class="card-title">How it works</h2>
            <p style="font-size: 13px; color: var(--text-secondary); margin-top: 0;">
                Set <code>PagingMode</code> to <code>Pages</code>, <code>LoadMore</code>, or
                <code>InfiniteScroll</code>. The grid calls your data provider with <code>IsAppend</code>
                set to <code>true</code> in the latter two modes.
            </p>
            <pre class="code-snippet"><code>@_usageSnippet</code></pre>
        </div>
    </CodeContent>
</DemoResultCodeTabs>

@code {
    private CloudDataGridPagingMode _mode = CloudDataGridPagingMode.Pages;
    private int _pageSize = 8;
    private int _gridKey;

    private readonly List<CloudDataGridColumn> _columns =
    [
        new() { Label = "Name", Key = "name", Width = 200 },
        new() { Label = "Email", Key = "email", Width = 250 },
        new() { Label = "Department", Key = "department", Width = 150 },
        new() { Label = "Country", Key = "country", Width = 130 }
    ];

    private void SetMode(CloudDataGridPagingMode mode)
    {
        if (_mode == mode) return;
        _mode = mode;
        ReloadGrid();
    }

    private void ReloadGrid() => _gridKey++;

    private async Task<CloudDataGridDataResult?> LoadAsync(CloudDataGridDataRequest request)
        => await Data.QueryAsync(request, ToRow);

    private static CloudDataGridRow ToRow(Person p) => new()
    {
        Id = p.Id,
        Cells = [p.FullName, p.Email, p.Department, p.Country]
    };

    private readonly string _usageSnippet = """
<!-- Pages: footer shows prev/next arrows, each page replaces rows -->
<CloudDataGrid PagingMode="CloudDataGridPagingMode.Pages"
           RowsPerPage="10"
           DataProvider="@LoadAsync" ... />

<!-- LoadMore: button appends next page, grid auto-scrolls -->
<CloudDataGrid PagingMode="CloudDataGridPagingMode.LoadMore"
           RowsPerPage="10"
           LoadMoreText="Load more employees"
           DataProvider="@LoadAsync" ... />

<!-- InfiniteScroll: auto-loads next page near scroll end -->
<CloudDataGrid PagingMode="CloudDataGridPagingMode.InfiniteScroll"
           RowsPerPage="10"
           DataProvider="@LoadAsync" ... />

@code {
    private async Task<CloudDataGridDataResult?> LoadAsync(CloudDataGridDataRequest request)
    {
        // request.IsAppend is true in LoadMore/InfiniteScroll modes
        return await DataService.QueryAsync(request, ToRow);
    }
}
""";
}
