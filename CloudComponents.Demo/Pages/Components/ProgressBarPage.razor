@page "/components/progressbar"

<PageTitle>Progress Bar — Cloud Components Demo</PageTitle>

<div class="page-header">
    <h1>Progress Bar</h1>
    <p>
        <code>ProgressBar</code> is a seekable range control available in three visual styles:
        <strong>Flat</strong>, <strong>Circle</strong>, and <strong>Disk</strong>.
        <code>OnChanging</code> fires continuously while dragging; <code>OnChanged</code> fires on release.
    </p>
</div>

<!-- ── Flat ───────────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Flat style</h2>
    <p class="card-subtitle">A horizontal seek bar. Drag the thumb or click anywhere on the track.</p>

    <ProgressBar Style="ProgressBarStyle.Flat"
                 Value="@_flatValue"
                 Total="100"
                 Step="1"
                 OnChanging="OnFlatChanging"
                 OnChanged="OnFlatChanged" />

    <p style="margin-top:.75rem;">
        Value: <span class="badge">@_flatValue.ToString("F0")</span>
        &nbsp; Seeking: <span class="badge">@_flatChanging.ToString("F0")</span>
    </p>
</div>

<!-- ── Disk ───────────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Disk style</h2>
    <p class="card-subtitle">Circular indicator commonly used for volume/media controls.</p>

    <ProgressBar Style="ProgressBarStyle.Disk"
                 Value="@_diskValue"
                 Total="1"
                 Step="0.01"
                 OnChanging="OnDiskChanging"
                 OnChanged="OnDiskChanged" />

    <p style="margin-top:.75rem;">
        Value: <span class="badge">@_diskValue.ToString("P0")</span>
        &nbsp; Seeking: <span class="badge">@_diskChanging.ToString("P0")</span>
    </p>
</div>

<!-- ── Circle ─────────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Circle style</h2>
    <p class="card-subtitle">Ring-shaped progress indicator.</p>

    <ProgressBar Style="ProgressBarStyle.Circle"
                 Value="@_circleValue"
                 Total="100"
                 Step="1"
                 OnChanging="OnCircleChanging"
                 OnChanged="OnCircleChanged" />

    <p style="margin-top:.75rem;">
        Value: <span class="badge">@_circleValue.ToString("F0")</span>
        &nbsp; Seeking: <span class="badge">@_circleChanging.ToString("F0")</span>
    </p>
</div>

<!-- ── Programmatic control ───────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Programmatic value</h2>
    <p class="card-subtitle">Set the flat bar's value directly from code.</p>

    <div class="toolbar">
        <button class="button" @onclick="@(() => SetFlat(0))">0 %</button>
        <button class="button" @onclick="@(() => SetFlat(25))">25 %</button>
        <button class="button" @onclick="@(() => SetFlat(50))">50 %</button>
        <button class="button" @onclick="@(() => SetFlat(75))">75 %</button>
        <button class="button" @onclick="@(() => SetFlat(100))">100 %</button>
    </div>
</div>

<!-- ── Event log ──────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Event log</h2>
    <div class="log">
        @if (_log.Count == 0)
        {
            <span class="log-empty">No events yet — seek a bar above.</span>
        }
        @foreach (var entry in _log)
        {
            <div class="log-line"><span class="log-time">@entry.Time</span>@entry.Message</div>
        }
    </div>
</div>

@code {
    private double _flatValue = 40;
    private double _flatChanging = 40;

    private double _diskValue = 0.6;
    private double _diskChanging = 0.6;

    private double _circleValue = 70;
    private double _circleChanging = 70;

    private List<LogEntry> _log = new();

    private void OnFlatChanging(ProgressBarChangeEventArgs e) { _flatChanging = e.NewValue; }
    private void OnFlatChanged(ProgressBarChangeEventArgs e)
    {
        _flatValue = e.NewValue;
        Log($"Flat changed → {e.NewValue:F0}");
    }

    private void OnDiskChanging(ProgressBarChangeEventArgs e) { _diskChanging = e.NewValue; }
    private void OnDiskChanged(ProgressBarChangeEventArgs e)
    {
        _diskValue = e.NewValue;
        Log($"Disk changed → {e.NewValue:P0}");
    }

    private void OnCircleChanging(ProgressBarChangeEventArgs e) { _circleChanging = e.NewValue; }
    private void OnCircleChanged(ProgressBarChangeEventArgs e)
    {
        _circleValue = e.NewValue;
        Log($"Circle changed → {e.NewValue:F0}");
    }

    private void SetFlat(double v)
    {
        _flatValue = v;
        _flatChanging = v;
        Log($"Flat set programmatically → {v:F0}");
    }

    private void Log(string msg) =>
        _log.Insert(0, new LogEntry(DateTime.Now.ToString("HH:mm:ss.fff"), msg));
}
