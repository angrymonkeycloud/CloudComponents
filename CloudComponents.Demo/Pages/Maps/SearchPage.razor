@page "/maps/search"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService

<PageTitle>CloudMaps — Search &amp; Locate</PageTitle>

<div class="page-header">
    <h1>Place Search &amp; Pin My Location</h1>
    <p>
        Use the built-in search box (top-left of the map) to find a place by name or address, or use the
        locate button to re-center on the device's current position. Both flows work through the same
        <code>ILocationService</code> abstraction across web and mobile.
    </p>
</div>

<MapsKeyGuard>
    <DemoResultCodeTabs>
        <ResultContent>
            <div class="card">
                <h2 class="card-title">Options</h2>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" @bind="_showBoundary" style="width: 16px; height: 16px;" />
                    Show boundary &amp; CloudGeography match when a city or area is found
                </label>
            </div>

            <div class="map-page-layout">
                <div>
                    <div class="card">
                        <h2 class="card-title">Map</h2>
                        <div class="map-host">
                            <AzureMap Height="500px"
                                      Width="100%"
                                      SubscriptionKey="@GetKey()"
                                      InitialView="_initialView"
                                      Style="MapStyle.Road"
                                      ShowSearchBox="true"
                                      SearchPlaceholder="Search for a city, address, or landmark…"
                                      SearchResultLimit="6"
                                      ShowCurrentLocationButton="true"
                                      OnMapReady="HandleMapReady"
                                      OnSearchResultSelected="HandleSearchResultSelected"
                                      OnMyLocationFound="HandleMyLocationFound"
                                      @ref="_map" />
                        </div>

                        <div class="toolbar" style="margin-top: 1rem;">
                            <button class="btn btn-primary" @onclick="PinMyLocation">📌 Pin My Location</button>
                            <button class="btn" @onclick="ClearSearch">Clear Search</button>
                            <span class="badge">@_status</span>
                        </div>
                    </div>
                </div>

                <div class="map-page-splitter" title="Drag to resize"></div>

                <div class="results-col">
                    @if (_lastSearchResult is { } r)
                    {
                        <div class="card">
                            <h2 class="card-title">🔎 Search Result</h2>
                            <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13px;">
                                <div><strong>Address:</strong> @r.Address</div>
                                @if (!string.IsNullOrEmpty(r.Description))
                                {
                                    <div><strong>Description:</strong> @r.Description</div>
                                }
                                <div><strong>Latitude:</strong> @r.Latitude.ToString("F5")</div>
                                <div><strong>Longitude:</strong> @r.Longitude.ToString("F5")</div>
                                @if (_showBoundary)
                                {
                                    <div style="margin-top: 4px;">
                                        @if (_boundaryShown)
                                        {
                                            <span class="badge" style="background: #0078d426; color: #0078d4; border: 1px solid #0078d4;">🗺 Boundary shown on map</span>
                                        }
                                        else
                                        {

                                            <span class="badge" style="background: var(--color-surface-2); color: var(--color-text-muted);">No boundary available for this result</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (_lastCoordinate is { } c)
                    {
                        <div class="card">
                            <h2 class="card-title">📌 My Location</h2>
                            <div style="font-size: 13px; display: flex; flex-direction: column; gap: 4px;">
                                <div><strong>Latitude:</strong> @c.Latitude.ToString("F5")</div>
                                <div><strong>Longitude:</strong> @c.Longitude.ToString("F5")</div>
                            </div>
                        </div>
                    }

                    @if (_showBoundary && _geoFieldMatches is not null)
                    {
                        <div class="card">
                            <h2 class="card-title">CloudGeography Match — @(_geoCountryName ?? "Unknown Country")</h2>
                            @if (_geoFieldMatches.Count == 0)
                            {
                                <p style="font-size: 13px; color: var(--color-text-muted);">No CloudGeography match found for this result.</p>
                            }
                            else
                            {
                                <div style="display: flex; flex-direction: column; gap: 10px;">
                                    @foreach (var (field, value, matchedName) in _geoFieldMatches)
                                    {
                                        <div style="font-size: 13px;">
                                            <div style="font-weight: 600; color: var(--color-accent); margin-bottom: 3px;">@field</div>
                                            <div style="margin-bottom: 4px; color: var(--color-text);">@value</div>
                                            @if (matchedName is not null)
                                            {
                                                <span class="badge" style="background: #0078d426; color: #0078d4; border: 1px solid #0078d4;">✓ @matchedName</span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background: var(--color-surface-2); color: var(--color-text-muted);">No match with CloudGeography</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </ResultContent>

        <CodeContent>
            <div class="card">
                <h2 class="card-title">How it works</h2>
                <ul style="font-size: 13px; color: var(--color-text-muted);">
                    <li><strong>Search:</strong> Debounced Azure Maps fuzzy search with a keyboard-navigable dropdown. Selecting a result flies the camera to it.</li>
                    <li><strong>Boundary:</strong> When the option is on, selecting a result creates a <code>MapZone</code> with the result address and calls <code>AddZonesAsync</code> — CloudMaps resolves the address to its administrative boundary polygon automatically. No manual geocoding or polygon-fetching required.</li>
                    <li><strong>CloudGeography:</strong> Each result field (Address, Description) is checked against <code>CloudGeographyClient</code> countries and subdivisions. Fields that match a CloudGeography entry are labelled; unmatched fields show "No match with CloudGeography".</li>
                    <li><strong>Pin my location (web):</strong> Uses <code>navigator.geolocation</code> through JS isolation (<code>WebLocationService</code>), registered in <code>Program.cs</code>.</li>
                    <li><strong>Pin my location (mobile):</strong> A .NET MAUI Blazor Hybrid host registers <code>MauiLocationService</code> instead — no component code changes required.</li>
                </ul>
                <pre class="code-snippet"><code>@_snippet</code></pre>
            </div>
        </CodeContent>
    </DemoResultCodeTabs>
</MapsKeyGuard>

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(37.7749, -122.4194, 11);
    private MapSearchResult? _lastSearchResult;
    private MapCoordinate? _lastCoordinate;
    private string _status = "Ready";
    private bool _showBoundary;
    private bool _boundaryShown;
    private string? _activeZoneId;
    private List<(string field, string value, string? matchedName)>? _geoFieldMatches;
    private string? _geoCountryName;

    private Task HandleMapReady() => Task.CompletedTask;

    private async Task HandleSearchResultSelected(MapSearchResult result)
    {
        _lastSearchResult = result;
        _status = "Search result selected";

        // Remove the previous zone before adding the new one.
        if (_activeZoneId is not null && _map is not null)
        {
            await _map.RemoveZoneAsync(_activeZoneId);
            _activeZoneId = null;
        }

        _boundaryShown = false;
        _geoFieldMatches = null;
        _geoCountryName = null;

        if (_showBoundary && _map is not null)
        {
            var zone = new MapZone
            {
                Addresses = [result.Address],
                Label = result.Address,
                FillColor = "#0078d426",
                StrokeColor = "#0078d4",
                StrokeWidth = 2
            };

            await _map.AddZonesAsync([zone]);
            _activeZoneId = zone.Id;
            _boundaryShown = true;

            await ResolveCloudGeographyAsync(result);
        }

        StateHasChanged();
    }

    private async Task ResolveCloudGeographyAsync(MapSearchResult result)
    {
        try
        {
            var geo = new CloudGeographyClient();
            var allCountries = geo.Countries.Get();

            var matchedCountry = allCountries
                .OrderByDescending(c => c.Name.Length)
                .FirstOrDefault(c => (result.Address + " " + result.Description)
                    .Contains(c.Name, StringComparison.OrdinalIgnoreCase));

            if (matchedCountry is null)
                return;

            _geoCountryName = matchedCountry.Name;
            var subdivisions = geo.Subdivisions.Get(matchedCountry.Code);

            string? FindMatch(string text)
            {
                var sub = subdivisions
                    .OrderByDescending(s => s.Name.Length)
                    .FirstOrDefault(s => text.Contains(s.Name, StringComparison.OrdinalIgnoreCase));
                if (sub is not null) return sub.Name;
                if (text.Contains(matchedCountry.Name, StringComparison.OrdinalIgnoreCase))
                    return matchedCountry.Name;
                return null;
            }

            var entries = new List<(string, string, string?)>
            {
                ("Address", result.Address, FindMatch(result.Address))
            };

            if (!string.IsNullOrEmpty(result.Description))
                entries.Add(("Description", result.Description, FindMatch(result.Description)));

            _geoFieldMatches = entries;
        }
        catch { /* best-effort */ }
    }

    private Task HandleMyLocationFound(MapCoordinate coordinate)
    {
        _lastCoordinate = coordinate;
        _status = "Location pinned";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task PinMyLocation()
    {
        if (_map is null) return;
        _status = "Locating…";
        StateHasChanged();
        var found = await _map.PinMyLocationAsync();
        if (!found) _status = "Location unavailable";
        StateHasChanged();
    }

    private async Task ClearSearch()
    {
        _map?.ClearSearch();
        _lastSearchResult = null;
        _geoFieldMatches = null;
        _geoCountryName = null;
        _boundaryShown = false;
        if (_map is not null)
        {
            if (_activeZoneId is not null)
                await _map.RemoveZoneAsync(_activeZoneId);
            else
                await _map.ClearZonesAsync();
        }
        _activeZoneId = null;
        _status = "Search cleared";
    }

    private string GetKey()
    {
        var key = ConfigService.GetSubscriptionKey();
        return !string.IsNullOrEmpty(key) ? key : Options.Value.SubscriptionKey ?? string.Empty;
    }

    private readonly string _snippet = """
<AzureMap ShowSearchBox="true"
          SearchPlaceholder="Search for a city, address, or landmark…"
          SearchResultLimit="6"
          ShowCurrentLocationButton="true"
          OnSearchResultSelected="HandleSearchResultSelected"
          OnMyLocationFound="HandleMyLocationFound"
          @ref="_map" />

// Show the boundary of the selected result as a MapZone (one call, no manual geocoding):
private async Task HandleSearchResultSelected(MapSearchResult result)
{
    var zone = new MapZone
    {
        Addresses = [result.Address],
        Label    = result.Address,
        FillColor  = "#0078d426",
        StrokeColor = "#0078d4"
    };
    await _map.AddZonesAsync([zone]);
}

// Multiple addresses share one zone / one color:
var zone = new MapZone
{
    Addresses = ["Lyon, France", "Marseille, France"],
    Label     = "Southern France",
    FillColor   = "#e8420026",
    StrokeColor = "#e84200"
};
await _map.AddZonesAsync([zone]);

// In Program.cs (web):
builder.Services.AddScoped<ILocationService, WebLocationService>();
""";
}

