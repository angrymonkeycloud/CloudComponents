@namespace CloudComponents.Grid.Components
@using CloudComponents.Grid.Models

@*
    CloudGridHeader — toolbar rendered above a CloudGrid.

    Naming: block `.cloudgridheader`, children `.cloudgridheader-*`, adjectives `._*`.

    Layout:
      [h2 label] [bulk actions]                       [right actions →]

    All actions — built-in (New, Search, View) and consumer-supplied — share the same
    CloudGridAction shape and are rendered by a single unified loop.

    When an Element action is active (._mode-active on the actions container) every
    inactive slot is hidden; the active slot expands to fill the row.

    All behavior lives in CloudGridHeader.razor.cs; styles in CloudGridHeader.razor.less.
*@

<div class="cloudgridheader">

    <h2>@Label</h2>

    @* ── Bulk actions (after title, visible only while rows are selected) ─── *@
    @if (HasVisibleBulkActions)
    {
        <div class="cloudgridheader-bulkactions">
            @foreach (CloudGridAction action in BulkHeaderActions)
            {
                <button type="button"
                        class="cloudgridheader-action @HeaderActionClasses(action, isBulk: true)"
                        title="@(action.Tooltip ?? action.Text)"
                        @onclick="() => FireActionClickedAsync(action, [..SelectedRecords])"
                        @onclick:stopPropagation
                        @onclick:preventDefault>
                    @ActionIconAndText(action)
                </button>
            }
        </div>
    }

    @* ── Right-side action slots ─────────────────────────────────────────── *@
    <div class="cloudgridheader-actions @ActionsClasses">

        @foreach (CloudGridAction action in AllHeaderActions)
        {
            bool isActive = _activeKey == action.Key;

            @if (action.Type == CloudGridActionType.Link)
            {
                <div class="cloudgridheader-slot">
                    <a class="cloudgridheader-action @HeaderActionClasses(action)"
                       href="@action.Href"
                       target="@action.Target"
                       title="@(action.Tooltip ?? action.Text)">
                        @ActionIconAndText(action)
                    </a>
                </div>
            }
            else if (action.Type == CloudGridActionType.Button)
            {
                <div class="cloudgridheader-slot">
                    <button type="button"
                            class="cloudgridheader-action @HeaderActionClasses(action)"
                            title="@(action.Tooltip ?? action.Text)"
                            @onclick="() => FireActionClickedAsync(action)"
                            @onclick:stopPropagation
                            @onclick:preventDefault>
                        @ActionIconAndText(action)
                    </button>
                </div>
            }
            else if (action.Type == CloudGridActionType.Element)
            {
                <div class="cloudgridheader-slot @SlotClasses(isActive)">
                    @if (isActive && action.ChildContent != null)
                    {
                        @action.ChildContent
                        <button type="button"
                                class="cloudgridheader-action _cancel"
                                @onclick="CancelActiveAsync"
                                @onclick:stopPropagation
                                @onclick:preventDefault>
                            cancel
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                class="cloudgridheader-action @HeaderActionClasses(action)"
                                title="@(action.Tooltip ?? action.Text)"
                                @onclick="() => HandleActivateAsync(action)"
                                @onclick:stopPropagation
                                @onclick:preventDefault>
                            @ActionIconAndText(action)
                        </button>
                    }
                </div>
            }
        }

        @if (ExtraActions != null)
        {
            @ExtraActions
        }

    </div>

</div>

@code {
    /// <summary>
    /// Shared helper: renders the icon SVG (if any) and text span (if any) for any action type.
    /// </summary>
    private RenderFragment ActionIconAndText(CloudGridAction action) => @<text>
        @{
            string? text = string.IsNullOrWhiteSpace(action.Text) ? action.Tooltip : action.Text;
        }
        @if (action.Icon != null)
        {
            @action.Icon
        }
        else if (!string.IsNullOrEmpty(action.IconSvg))
        {
            @((MarkupString)action.IconSvg)
        }
        @if (!string.IsNullOrWhiteSpace(text))
        {
            <span>@text</span>
        }
    </text>;

    /// <summary>
    /// RenderFragment assigned as the ChildContent of the built-in Search action.
    /// Defined here so it can reference @ref and event handlers declared in the partial class.
    /// </summary>
    private RenderFragment SearchContent => @<text>
        <input @ref="_searchInput"
               type="search"
               class="cloudgridheader-search"
               value="@_searchQuery"
               placeholder="Search..."
               @oninput="OnSearchInputAsync"
               @onblur="OnSearchBlurAsync"
               @onkeydown="OnSearchKeyDownAsync" />
    </text>;
}

