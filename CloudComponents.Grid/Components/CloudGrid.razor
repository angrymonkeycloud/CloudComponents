@namespace CloudComponents.Grid.Components
@using CloudComponents.Grid.Models

@*
    CloudGrid — single entry point for the full grid experience.

    Composes CloudGridHeader (optional), CloudGridBody and CloudGridFooter internally.
    Developers use only this component and configure each section via Header options
    and the shared Actions list.

    Markup follows the Angry Monkey CSS naming convention
    (https://github.com/angrymonkeydocs/css-naming-convention):
    - Block:       .cloudgrid
    - Children:    .cloudgrid-head, .cloudgrid-headcell, .cloudgrid-row, ...
    - Adjectives:  ._busy, ._sortable, ._sorted-ascending, ._selected, ...

    All behavior lives in CloudGrid.razor.cs; styles in CloudGrid.razor.less.
*@

<div class="cloudgrid @RootClass" style="@RootStyle" @attributes="AdditionalAttributes">

    @* ── Header (optional) ──────────────────────────────────────────────── *@
    @if (Header != null)
    {
        <CloudGridHeader Label="@Header.Label"
                         Actions="@Header.Actions"
                         OnActionClicked="@Header.OnActionClicked"
                         SelectedRecords="@HeaderSelectedRecords"
                         AllowSearch="@Header.AllowSearch"
                         SearchDebounceMilliseconds="@Header.SearchDebounceMilliseconds"
                         OnSearchChanged="@Header.OnSearchChanged"
                         ExtraActions="@Header.ExtraActions" />
    }

    @* ── Bulk selection hidden field ────────────────────────────────────── *@
    @if (AllowSelection)
    {
        <input type="hidden" id="SelectedRecords" value="@string.Join(",", _selectedRecords)" />
    }

    @* ── Body (table head + rows + shields) ─────────────────────────────── *@
    <CloudGridBody Columns="@Columns"
                   Data="@Data"
                   IsLoading="@IsLoading"
                   IsSearching="@IsSearching"
                   Message="@Message"
                   AllowSelection="@AllowSelection"
                   SelectedRecords="@_selectedRecords"
                   SelectedRecordsChanged="@OnBodySelectionChanged"
                   AllowReordering="@AllowReordering"
                   OnRowsReordered="@OnRowsReordered"
                   RowActions="@AllRowActions"
                   ActionFilter="@ActionFilter"
                   OnActionClicked="@OnActionClicked"
                   LinkTarget="@LinkTarget"
                   LoadingText="@LoadingText"
                   SearchingText="@SearchingText"
                   EmptyCellText="@EmptyCellText"
                   RowHeight="@RowHeight"
                   RowsPerPage="@RowsPerPage"
                   PagingMode="@PagingMode"
                   LoadMoreText="@LoadMoreText"
                   OnPageChanged="@OnPageChanged"
                   OnSortChanged="@OnSortChanged"
                   OnResizingChanged="@OnBodyResizingChanged"
                   OnDraggingChanged="@OnBodyDraggingChanged" />

    @* ── Footer (range info + pager) ────────────────────────────────────── *@
    <CloudGridFooter Data="@Data"
                     PagingMode="@PagingMode"
                     RangeStart="@FooterRangeStart"
                     RangeEnd="@FooterRangeEnd"
                     HasPreviousPage="@FooterHasPreviousPage"
                     HasNextPage="@FooterHasNextPage"
                     OnPageChanged="@OnPageChanged" />

</div>

