@page "/compare"

<PageTitle>CloudIcons Demo — Compare</PageTitle>

<div class="page-header">
    <h1>Compare</h1>
    <p>Place any two assets side by side with shared size and color controls to compare stroke weight, proportion, and visual weight.</p>
</div>

<div class="controls-bar">
    <label>
        Size
        <input type="range" min="16" max="128" step="4" @bind="size" @bind:event="oninput" />
        <span class="value-badge">@size px</span>
    </label>
    <label>
        Color
        <input type="color" @bind="color" @bind:event="oninput" />
        <span class="value-badge">@color</span>
    </label>
    <label class="toggle-wrap">
        <span class="toggle">
            <input type="checkbox" @bind="useDefaultTheme" />
            <span class="toggle-track"></span>
            <span class="toggle-thumb"></span>
        </span>
        Brand colors (logos)
    </label>
</div>

<div class="compare-grid">
    @for (int slot = 0; slot < 2; slot++)
    {
        var s = slot; // capture for lambda
        var entry = s == 0 ? leftKey : rightKey;
        var item = AllItems.FirstOrDefault(i => i.Key == entry);
        <div class="compare-slot">
            <h3>Slot @(s + 1)</h3>
            <select value="@entry" @onchange="e => SetSlot(s, e.Value?.ToString() ?? string.Empty)">
                <option value="">— select —</option>
                <optgroup label="Icons">
                    @foreach (var icon in AllItems.Where(i => i.Category == "Icon"))
                    {
                        <option value="@icon.Key">@icon.Key</option>
                    }
                </optgroup>
                <optgroup label="Logos">
                    @foreach (var logo in AllItems.Where(i => i.Category == "Logo"))
                    {
                        <option value="@logo.Key">@logo.Key</option>
                    }
                </optgroup>
            </select>

            @if (item is not null)
            {
                <div class="compare-preview">
                    <div style="width:@(item.Wide ? (int)Math.Round(size * 5.0) : size)px;height:@(size)px;color:@color;">
                        @item.Render(useDefaultTheme)
                    </div>
                </div>
                <div class="compare-meta">
                    @item.Key <span>(@item.Category)</span>
                </div>
                <pre class="code-snippet">@item.Snippet(useDefaultTheme)</pre>
            }
            else
            {
                <div class="compare-preview" style="min-height:@(Math.Max(size + 32, 80))px;">
                    <span style="color:var(--demo-muted);font-size:0.85rem;">Nothing selected</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private int size = 48;
    private string color = "#1f2430";
    private bool useDefaultTheme = true;
    private string leftKey = "SearchIcon";
    private string rightKey = "GoogleLogo";

    private void SetSlot(int slot, string key)
    {
        if (slot == 0) leftKey = key;
        else rightKey = key;
    }

    private record CompareItem(string Key, string Category, bool Wide,
        Func<bool, RenderFragment> Render, Func<bool, string> Snippet);

    private static readonly List<CompareItem> AllItems = new()
    {
        // Icons
        new("AddIcon",           "Icon",  false, _ => @<AddIcon />,            _ => "<AddIcon />"),
        new("Cast",              "Icon",  false, _ => @<Cast />,               _ => "<Cast />"),
        new("Checkmark",         "Icon",  false, _ => @<Checkmark />,          _ => "<Checkmark />"),
        new("ChevronIcon",       "Icon",  false, _ => @<ChevronIcon />,        _ => "<ChevronIcon />"),
        new("Close",             "Icon",  false, _ => @<Close />,              _ => "<Close />"),
        new("CloseIcon",         "Icon",  false, _ => @<CloseIcon />,          _ => "<CloseIcon />"),
        new("CrossIcon",         "Icon",  false, _ => @<CrossIcon />,          _ => "<CrossIcon />"),
        new("DragIcon",          "Icon",  false, _ => @<DragIcon />,           _ => "<DragIcon />"),
        new("ExitFullscreenIcon","Icon",  false, _ => @<ExitFullscreenIcon />, _ => "<ExitFullscreenIcon />"),
        new("ExpandIcon",        "Icon",  false, _ => @<ExpandIcon />,         _ => "<ExpandIcon />"),
        new("FullscreenIcon",    "Icon",  false, _ => @<FullscreenIcon />,     _ => "<FullscreenIcon />"),
        new("Loading",           "Icon",  false, _ => @<Loading />,            _ => "<Loading />"),
        new("PauseButton",       "Icon",  false, _ => @<PauseButton />,        _ => "<PauseButton />"),
        new("PlayButton",        "Icon",  false, _ => @<PlayButton />,         _ => "<PlayButton />"),
        new("RefreshIcon",       "Icon",  false, _ => @<RefreshIcon />,        _ => "<RefreshIcon />"),
        new("ReorderIcon",       "Icon",  false, _ => @<ReorderIcon />,        _ => "<ReorderIcon />"),
        new("SaveIcon",          "Icon",  false, _ => @<SaveIcon />,           _ => "<SaveIcon />"),
        new("SearchIcon",        "Icon",  false, _ => @<SearchIcon />,         _ => "<SearchIcon />"),
        new("SettingsIcon",      "Icon",  false, _ => @<SettingsIcon />,       _ => "<SettingsIcon />"),
        new("SortIcon",          "Icon",  false, _ => @<SortIcon />,           _ => "<SortIcon />"),
        new("StopIcon",          "Icon",  false, _ => @<StopIcon />,           _ => "<StopIcon />"),
        new("Volume",            "Icon",  false, _ => @<Volume />,             _ => "<Volume />"),
        new("VolumeMute",        "Icon",  false, _ => @<VolumeMute />,         _ => "<VolumeMute />"),

        // Logos
        new("AngryMonkeyCloudLogo", "Logo", true,
            _ => @<AngryMonkeyCloudLogo />,
            _ => "<AngryMonkeyCloudLogo />"),

        new("AppleLogo", "Logo", false,
            t => t ? @<AppleLogo UseDefaultTheme="true" /> : @<AppleLogo />,
            t => t ? "<AppleLogo UseDefaultTheme=\"true\" />" : "<AppleLogo />"),

        new("FacebookLogo", "Logo", false,
            t => t ? @<FacebookLogo UseDefaultTheme="true" /> : @<FacebookLogo />,
            t => t ? "<FacebookLogo UseDefaultTheme=\"true\" />" : "<FacebookLogo />"),

        new("GoogleLogo", "Logo", false,
            t => t ? @<GoogleLogo UseDefaultTheme="true" /> : @<GoogleLogo />,
            t => t ? "<GoogleLogo UseDefaultTheme=\"true\" />" : "<GoogleLogo />"),

        new("InstagramLogo", "Logo", false,
            t => t ? @<InstagramLogo UseDefaultTheme="true" /> : @<InstagramLogo />,
            t => t ? "<InstagramLogo UseDefaultTheme=\"true\" />" : "<InstagramLogo />"),

        new("MetaLogo", "Logo", false,
            t => t ? @<MetaLogo UseDefaultTheme="true" /> : @<MetaLogo />,
            t => t ? "<MetaLogo UseDefaultTheme=\"true\" />" : "<MetaLogo />"),

        new("MicrosoftLogo", "Logo", false,
            t => t ? @<MicrosoftLogo UseDefaultTheme="true" /> : @<MicrosoftLogo />,
            t => t ? "<MicrosoftLogo UseDefaultTheme=\"true\" />" : "<MicrosoftLogo />"),

        new("TwitterLogo", "Logo", false,
            t => t ? @<TwitterLogo UseDefaultTheme="true" /> : @<TwitterLogo />,
            t => t ? "<TwitterLogo UseDefaultTheme=\"true\" />" : "<TwitterLogo />"),
    };
}
