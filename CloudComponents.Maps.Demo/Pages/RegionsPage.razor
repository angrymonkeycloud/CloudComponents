@page "/regions"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService

<PageTitle>CloudMaps — Regions & Zones</PageTitle>

<div class="page-header">
    <h1>Regions & Administrative Boundaries</h1>
    <p>
        Display administrative regions as colored overlays on the map. Each region is fetched using
        Cloud Geography subdivisions and Azure Maps polygon API. Select a country to view its subdivisions.
    </p>
</div>

<div class="card">
    <h2 class="card-title">Settings</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px;">Select Country:</label>
            <select @onchange="HandleCountrySelected" style="width: 100%;">
                <option value="">-- Choose a country --</option>
                <option value="US">United States</option>
                <option value="CA">Canada</option>
                <option value="GB">United Kingdom</option>
                <option value="DE">Germany</option>
                <option value="FR">France</option>
                <option value="AU">Australia</option>
                <option value="MX">Mexico</option>
            </select>
        </div>
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px;">Region Color:</label>
            <input type="color" @bind="_regionFillColor" style="width: 100%; height: 40px; border: 1px solid #ccc; border-radius: 4px; cursor: pointer;" />
        </div>
    </div>

    <div class="toolbar">
        <button class="primary" @onclick="LoadRegions" disabled="@(_selectedCountryCode == "" || _isLoadingRegions)">
            @(_isLoadingRegions ? "Loading..." : "Load Regions")
        </button>
        <button @onclick="ClearRegions" disabled="@(_regionCount == 0)">Clear All</button>
        <span class="badge">Regions: @_regionCount</span>
        <span class="badge" style="@(_isLoadingRegions ? "opacity: 0.6;" : "")">@_status</span>
    </div>
</div>

<div class="card">
    <h2 class="card-title">📍 Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  ShowCurrentLocationButton="false"
                  Regions="@_regions"
                  OnMapReady="HandleMapReady"
                  @ref="_map" />
    </div>
</div>

@if (_subdivisions != null && _subdivisions.Count > 0)
{
    <div class="card">
        <h2 class="card-title">Subdivision Details</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;">
            @foreach (var subdivision in _subdivisions)
            {
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                    <div style="font-weight: 600; margin-bottom: 6px; color: #0078d4;">
                        @subdivision.Code
                    </div>
                    <div><strong>Name:</strong> @subdivision.Name</div>
                    <div><strong>Type:</strong> @subdivision.Type</div>
                    @if (subdivision.Children?.Count > 0)
                    {
                        <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #e0e0e0;">
                            <strong>Children: @subdivision.Children.Count</strong>
                            <ul style="margin: 6px 0 0 16px; padding: 0;">
                                @foreach (var child in subdivision.Children.Take(3))
                                {
                                    <li style="font-size: 11px;">@child.Code - @child.Name</li>
                                }
                                @if (subdivision.Children.Count > 3)
                                {
                                    <li style="font-size: 11px; color: #999;">+@(subdivision.Children.Count - 3) more</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(39.8283, -98.5795, 4);

    private string _selectedCountryCode = "";
    private string _regionFillColor = "rgba(0, 120, 212, 0.15)";
    private string _regionStrokeColor = "#0078d4";
    private double _regionStrokeWidth = 2;

    private List<MapRegion> _regions = new();
    private List<Subdivision>? _subdivisions;
    private int _regionCount;
    private bool _isLoadingRegions;
    private string _status = "Ready";

    private readonly Dictionary<string, (double lat, double lng, double zoom)> _countryViews = new()
    {
        { "US", (39.8283, -98.5795, 4) },
        { "CA", (56.1304, -106.3468, 4) },
        { "GB", (55.3781, -3.4360, 6) },
        { "DE", (51.1657, 10.4515, 6) },
        { "FR", (46.2276, 2.2137, 6) },
        { "AU", (-25.2744, 133.7751, 4) },
        { "MX", (23.6345, -102.5528, 5) },
    };

    private async Task HandleMapReady()
    {
        // Map is ready
    }

    private async Task HandleCountrySelected(ChangeEventArgs e)
    {
        _selectedCountryCode = e.Value?.ToString() ?? "";
        _regions.Clear();
        _regionCount = 0;

        if (_selectedCountryCode != "" && _map != null)
        {
            // Center map on country
            if (_countryViews.TryGetValue(_selectedCountryCode, out var view))
            {
                await _map.SetCenterAsync(view.lat, view.lng, (int)view.zoom);
            }
        }
    }

    private async Task LoadRegions()
    {
        if (string.IsNullOrEmpty(_selectedCountryCode) || _map == null)
            return;

        _isLoadingRegions = true;
        _status = "Loading regions...";
        StateHasChanged();

        try
        {
            // Load subdivisions from Cloud Geography
            var geoClient = new CloudGeographyClient();
            _subdivisions = geoClient.Subdivisions.Get(_selectedCountryCode);

            if (_subdivisions == null || _subdivisions.Count == 0)
            {
                _status = "No subdivisions found";
                return;
            }

            await _map.ClearRegionsAsync();
            _regions.Clear();

            // Try to fetch polygon boundaries for each subdivision (limited to first 5 to avoid API overload)
            var toProcess = _subdivisions.Take(5).ToList();

            foreach (var subdivision in toProcess)
            {
                try
                {
                    // Note: In a real implementation, you would use the Azure Maps Search Polygon API
                    // to fetch the actual polygon coordinates for each subdivision.
                    // For this demo, we'll create sample regions as a fallback.

                    // Example: This would use geocoding to get bounds
                    var geocodeResult = await _map.GeocodeAsync($"{subdivision.Name}, {_selectedCountryCode}");

                    if (geocodeResult != null)
                    {
                        // Create a sample region (in production, fetch actual polygon)
                        var polygon = CreateSamplePolygon(
                            geocodeResult.South, geocodeResult.West,
                            geocodeResult.North, geocodeResult.East);

                        var region = new MapRegion(
                            polygon,
                            FillColor: _regionFillColor,
                            StrokeColor: _regionStrokeColor,
                            StrokeWidth: _regionStrokeWidth)
                        {
                            Label = subdivision.Code
                        };

                        _regions.Add(region);
                    }
                }
                catch
                {
                    // Continue with next subdivision
                }
            }

            if (_regions.Count > 0)
            {
                await _map.AddRegionsAsync(_regions);
                _regionCount = _regions.Count;
                _status = $"Loaded {_regionCount} regions";
            }
            else
            {
                _status = "Could not load region boundaries";
            }
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoadingRegions = false;
            StateHasChanged();
        }
    }

    private async Task ClearRegions()
    {
        if (_map != null)
        {
            await _map.ClearRegionsAsync();
        }
        _regions.Clear();
        _regionCount = 0;
        _status = "Regions cleared";
        StateHasChanged();
    }

    /// <summary>
    /// Create a sample polygon from bounding box coordinates (for demo purposes).
    /// In production, use actual GeoJSON polygon from Azure Maps Search Polygon API.
    /// </summary>
    private double[][][] CreateSamplePolygon(double south, double west, double north, double east)
    {
        // Create a simple rectangular polygon
        double[][] ring = new[]
        {
            new[] { west, south },
            new[] { east, south },
            new[] { east, north },
            new[] { west, north },
            new[] { west, south }  // Close the ring
        };

        // Add slight variations for a more realistic look
        var random = new Random();
        for (int i = 0; i < ring.Length - 1; i++)
        {
            ring[i][0] += (random.NextDouble() - 0.5) * 0.1;
            ring[i][1] += (random.NextDouble() - 0.5) * 0.1;
        }

        return new[] { ring };
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }
}
