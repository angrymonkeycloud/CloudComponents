@page "/live-tracking"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService
@inject SampleTrackingService TrackingService
@implements IAsyncDisposable

<PageTitle>CloudMaps — Live Tracking</PageTitle>

<div class="page-header">
    <h1>Live Position Tracking</h1>
    <p>
        Real-time tracking of one or multiple moving objects. Simulated GPS updates show current position
        and historical trail. Perfect for fleet management, delivery tracking, or asset monitoring scenarios.
    </p>
</div>

<DemoResultCodeTabs>
    <ResultContent>
        <div class="card">
    <h2 class="card-title">Tracking Controls</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;">
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px;">Update Interval (ms):</label>
            <input type="number" @bind="_updateIntervalMs" min="100" max="5000" step="100" style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px;">Tracking Mode:</label>
            <select @bind="_trackingMode" style="width: 100%;">
                <option value="single">Single Vehicle</option>
                <option value="multi">Multiple Vehicles</option>
            </select>
        </div>
        <div style="display: flex; gap: 8px; align-items: flex-end;">
            <button class="primary" @onclick="StartTracking" disabled="@_isTracking" style="flex: 1;">
                @(_isTracking ? "Tracking..." : "Start Tracking")
            </button>
            <button @onclick="StopTracking" disabled="@(!_isTracking)" style="flex: 1;">Stop</button>
            <button @onclick="ResetTracking" style="flex: 1;">Reset</button>
        </div>
    </div>
</div>

<div class="card">
    <h2 class="card-title">📍 Live Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  ShowCurrentLocationButton="false"
                  Markers="@_liveMarkers"
                  OnMapReady="HandleMapReady"
                  @ref="_map" />
    </div>
</div>

<div class="card">
    <h2 class="card-title">📊 Active Trackers</h2>
    @if (_trackers.Count == 0)
    {
        <p style="color: #999; font-size: 13px;">No active trackers. Start tracking to begin monitoring positions.</p>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px;">
            @foreach (var tracker in _trackers)
            {
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <div style="width: 16px; height: 16px; background: @tracker.Color; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 0 2px @tracker.Color;"></div>
                        <div style="font-weight: 600; color: #111; flex: 1;">@tracker.Name</div>
                    </div>
                    <div style="margin: 6px 0;"><strong>Latitude:</strong> @tracker.CurrentLat.ToString("F5")</div>
                    <div style="margin: 6px 0;"><strong>Longitude:</strong> @tracker.CurrentLng.ToString("F5")</div>
                    <div style="margin: 6px 0;"><strong>Last Update:</strong> @tracker.LastUpdate.ToString("HH:mm:ss")</div>
                    <div style="margin: 6px 0; color: #666;"><strong>Position History:</strong> @tracker.PositionHistory.Count points</div>
                </div>
            }
        </div>
    }
</div>
    </ResultContent>

    <CodeContent>
        <div class="card">
            <h2 class="card-title">How to implement in your app</h2>
            <p style="font-size: 13px; color: #666; margin-top: 0;">
                Live tracking is just markers you keep moving. On a timer, recompute each tracked object's
                coordinate, rebuild the marker list, and call <code>ClearMarkersAsync</code> +
                <code>AddMarkersAsync</code> to push the new positions to the map.
            </p>
            <pre class="code-snippet"><code>@_usageSnippet</code></pre>
        </div>
    </CodeContent>
</DemoResultCodeTabs>

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(37.7749, -122.4194, 13);

    private readonly string _usageSnippet = """
<AzureMap Markers="@_liveMarkers"
          OnMapReady="HandleMapReady"
          @ref="_map" />

@code {
    private AzureMap? _map;
    private List<MapMarker> _liveMarkers = new();
    private PeriodicTimer? _timer;

    private async Task StartTrackingAsync()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        while (await _timer.WaitForNextTickAsync())
        {
            // Recompute positions from your own GPS/telemetry source, then push them to the map
            _liveMarkers = GetLatestMarkerPositions();
            await _map!.ClearMarkersAsync();
            await _map.AddMarkersAsync(_liveMarkers);
        }
    }
}
""";

    private List<LiveTracker> _trackers = new();
    private List<MapMarker> _liveMarkers = new();
    private int _updateIntervalMs = 1000;
    private string _trackingMode = "single";
    private bool _isTracking;
    private CancellationTokenSource? _trackingCts;
    private Task? _trackingTask;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    private async Task HandleMapReady()
    {
        // Map is ready
    }

    private async Task StartTracking()
    {
        if (_isTracking) return;

        _isTracking = true;
        _trackingCts = new CancellationTokenSource();

        // Initialize trackers
        _trackers.Clear();
        _liveMarkers.Clear();

        if (_trackingMode == "single")
        {
            var tracker = TrackingService.CreateLiveTracker("Vehicle 1", 37.7749, -122.4194);
            tracker.Color = "#0078d4";
            _trackers.Add(tracker);
        }
        else
        {
            var trackers = new[]
            {
                TrackingService.CreateLiveTracker("Vehicle 1", 37.7749, -122.4194),
                TrackingService.CreateLiveTracker("Vehicle 2", 37.7849, -122.4100),
                TrackingService.CreateLiveTracker("Vehicle 3", 37.7649, -122.4300),
            };
            var colors = new[] { "#0078d4", "#107c10", "#c50f1f" };
            for (int i = 0; i < trackers.Length; i++)
            {
                trackers[i].Color = colors[i];
                _trackers.Add(trackers[i]);
            }
        }

        // Add initial markers
        foreach (var tracker in _trackers)
        {
            _liveMarkers.Add(tracker.ToMarker());
        }

        if (_map != null)
        {
            await _map.AddMarkersAsync(_liveMarkers);
        }

        StateHasChanged();

        // Start tracking loop
        _trackingTask = TrackingLoop(_trackingCts.Token);
    }

    private async Task TrackingLoop(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(_updateIntervalMs, ct);

                // Update each tracker's position
                foreach (var tracker in _trackers)
                {
                    var (newLat, newLng) = TrackingService.SimulateNextPosition(tracker);
                    tracker.UpdatePosition(newLat, newLng);
                }

                // Update markers on map
                if (_map != null)
                {
                    await _map.ClearMarkersAsync();
                    _liveMarkers.Clear();

                    foreach (var tracker in _trackers)
                    {
                        _liveMarkers.Add(tracker.ToMarker());
                    }

                    await _map.AddMarkersAsync(_liveMarkers);
                }

                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch
            {
                // Continue on errors
            }
        }
    }

    private async Task StopTracking()
    {
        _isTracking = false;
        _trackingCts?.Cancel();
        if (_trackingTask != null)
        {
            try
            {
                await _trackingTask;
            }
            catch (OperationCanceledException) { }
        }
        StateHasChanged();
    }

    private async Task ResetTracking()
    {
        await StopTracking();
        _trackers.Clear();
        _liveMarkers.Clear();
        if (_map != null)
        {
            await _map.ClearMarkersAsync();
        }
        StateHasChanged();
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await StopTracking();
        _trackingCts?.Dispose();
    }
}
