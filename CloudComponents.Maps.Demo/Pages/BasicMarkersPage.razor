@page "/basic-markers"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService

<PageTitle>CloudMaps — Basic Markers</PageTitle>

<div class="page-header">
    <h1>Basic Markers</h1>
    <p>
        Double-click on an empty area to add a marker. Drag a marker to update its coordinates.
        Double-click a marker to remove it. All markers and their coordinates are displayed below the map.
    </p>
</div>

<div class="card">
    <h2 class="card-title">Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  AddMarkerTrigger="MarkerAddTrigger.DoubleClick"
                  AllowMarkerRemoval="true"
                  ShowTrafficFlow="false"
                  ShowCurrentLocationButton="true"
                  Markers="@_markers"
                  OnMapReady="HandleMapReady"
                  OnMarkerAdded="HandleMarkerAdded"
                  OnMarkerRemoved="HandleMarkerRemoved"
                  OnMarkerClick="HandleMarkerClick"
                  @ref="_map" />
    </div>

    <div class="toolbar" style="margin-top: 1rem;">
        <button class="primary" @onclick="ClearAllMarkers">Clear All Markers</button>
        <button @onclick="AddSampleMarkers">Add Sample Markers</button>
        <span class="badge">Markers: @_markers.Count</span>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Marker Details</h2>
    @if (_markers.Count == 0)
    {
        <p style="color: #999; font-size: 13px;">No markers yet. Double-click on the map to add markers.</p>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px;">
            @foreach (var marker in _markers)
            {
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #0078d4;">Marker @_markers.IndexOf(marker).ToString()</div>
                    <div style="margin: 4px 0;"><strong>ID:</strong> <code>@marker.Id.Substring(0, 8)...</code></div>
                    <div style="margin: 4px 0;"><strong>Latitude:</strong> @marker.Latitude.ToString("F5")</div>
                    <div style="margin: 4px 0;"><strong>Longitude:</strong> @marker.Longitude.ToString("F5")</div>
                    <div style="margin: 4px 0;"><strong>Label:</strong> @(marker.Label ?? "(none)")</div>
                    <button style="margin-top: 8px; padding: 4px 8px; font-size: 11px;" @onclick="() => RemoveMarker(marker.Id)">Remove</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private AzureMap? _map;
    private readonly List<MapMarker> _markers = new();
    private readonly InitialMapView _initialView = new(37.7749, -122.4194, 13);

    private async Task HandleMapReady()
    {
        // Map is ready for interaction
    }

    private async Task HandleMarkerAdded(MapMarker marker)
    {
        _markers.Add(marker);
        StateHasChanged();
    }

    private async Task HandleMarkerRemoved(MapMarker marker)
    {
        _markers.Remove(marker);
        StateHasChanged();
    }

    private async Task HandleMarkerClick(MapMarker marker)
    {
        // Marker clicked, could show details popup or navigate
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }

    private async Task ClearAllMarkers()
    {
        if (_map != null)
        {
            await _map.ClearMarkersAsync();
            _markers.Clear();
            StateHasChanged();
        }
    }

    private async Task AddSampleMarkers()
    {
        if (_map == null) return;

        var samples = new[]
        {
            new MapMarker(37.7749, -122.4194, "San Francisco"),
            new MapMarker(34.0522, -118.2437, "Los Angeles"),
            new MapMarker(47.6062, -122.3321, "Seattle"),
        };

        foreach (var marker in samples)
        {
            _markers.Add(marker);
            await _map.AddMarkerAsync(marker);
        }

        StateHasChanged();
    }

    private async Task RemoveMarker(string id)
    {
        if (_map != null)
        {
            await _map.RemoveMarkerAsync(id);
            _markers.RemoveAll(m => m.Id == id);
            StateHasChanged();
        }
    }
}
