@page "/search-and-locate"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService

<PageTitle>CloudMaps — Search &amp; Pin My Location</PageTitle>

<div class="page-header">
    <h1>Place Search &amp; Pin My Location</h1>
    <p>
        Use the built-in search box (top-left of the map) to find a place by name or address, or use the
        locate button to recenter on the device's current position. Both flows work on web and mobile
        through the same <code>ILocationService</code> abstraction.
    </p>
</div>

<div class="card">
    <h2 class="card-title">📍 Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  ShowSearchBox="true"
                  SearchPlaceholder="Search for a city, address, or landmark…"
                  SearchResultLimit="6"
                  ShowCurrentLocationButton="true"
                  OnMapReady="HandleMapReady"
                  OnSearchResultSelected="HandleSearchResultSelected"
                  OnMyLocationFound="HandleMyLocationFound"
                  @ref="_map" />
    </div>

    <div class="toolbar" style="margin-top: 1rem;">
        <button class="primary" @onclick="PinMyLocation">Pin My Location</button>
        <button @onclick="ClearSearch">Clear Search</button>
        <span class="badge">@_status</span>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Last Result</h2>
    @if (_lastSearchResult is null && _lastCoordinate is null)
    {
        <p style="color: #999; font-size: 13px;">
            Search for a place or pin your location to see details here.
        </p>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;">
            @if (_lastSearchResult is { } result)
            {
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #0078d4;">🔎 Search Result</div>
                    <div style="margin: 4px 0;"><strong>Address:</strong> @result.Address</div>
                    @if (!string.IsNullOrEmpty(result.Description))
                    {
                        <div style="margin: 4px 0;"><strong>Description:</strong> @result.Description</div>
                    }
                    <div style="margin: 4px 0;"><strong>Latitude:</strong> @result.Latitude.ToString("F5")</div>
                    <div style="margin: 4px 0;"><strong>Longitude:</strong> @result.Longitude.ToString("F5")</div>
                </div>
            }
            @if (_lastCoordinate is { } coordinate)
            {
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                    <div style="font-weight: 600; margin-bottom: 8px; color: #0078d4;">📌 My Location</div>
                    <div style="margin: 4px 0;"><strong>Latitude:</strong> @coordinate.Latitude.ToString("F5")</div>
                    <div style="margin: 4px 0;"><strong>Longitude:</strong> @coordinate.Longitude.ToString("F5")</div>
                </div>
            }
        </div>
    }
</div>

<div class="card">
    <h2 class="card-title">How it works</h2>
    <ul>
        <li><strong>Search:</strong> Debounced Azure Maps fuzzy search with a keyboard-navigable dropdown (Arrow keys + Enter/Escape). Selecting a result flies the camera to it.</li>
        <li><strong>Pin my location (web):</strong> Uses <code>navigator.geolocation</code> through JS isolation (<code>CloudComponents.Maps.Web</code>'s <code>WebLocationService</code>), registered in <code>Program.cs</code>.</li>
        <li><strong>Pin my location (mobile):</strong> A .NET MAUI Blazor Hybrid host would instead register <code>CloudComponents.Maps.Mobile</code>'s <code>MauiLocationService</code>, which uses native <code>Geolocation</code>/<code>Permissions</code> APIs — no component code changes required.</li>
        <li><strong>Permission consent:</strong> The component shows its own confirmation popup before requesting the OS/browser permission prompt, keeping the UX consistent across platforms.</li>
    </ul>

    <h3 style="margin-top: 12px;">Usage snippet</h3>
    <pre class="code-snippet"><code>@_usageSnippet</code></pre>
</div>

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(37.7749, -122.4194, 11);
    private readonly string _usageSnippet = """
<AzureMap ShowSearchBox=\"true\"
          SearchPlaceholder=\"Search for a city, address, or landmark…\"
          SearchResultLimit=\"6\"
          ShowCurrentLocationButton=\"true\"
          OnSearchResultSelected=\"HandleSearchResultSelected\"
          OnMyLocationFound=\"HandleMyLocationFound\"
          @ref=\"_map\" />
""";

    private MapSearchResult? _lastSearchResult;
    private MapCoordinate? _lastCoordinate;
    private string _status = "Ready";

    private Task HandleMapReady() => Task.CompletedTask;

    private Task HandleSearchResultSelected(MapSearchResult result)
    {
        _lastSearchResult = result;
        _status = "Search result selected";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleMyLocationFound(MapCoordinate coordinate)
    {
        _lastCoordinate = coordinate;
        _status = "Location pinned";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task PinMyLocation()
    {
        if (_map is null) return;

        _status = "Locating…";
        StateHasChanged();

        var found = await _map.PinMyLocationAsync();
        if (!found)
            _status = "Location unavailable";

        StateHasChanged();
    }

    private void ClearSearch()
    {
        _map?.ClearSearch();
        _lastSearchResult = null;
        _status = "Search cleared";
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }
}
