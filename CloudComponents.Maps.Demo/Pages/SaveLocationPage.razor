@page "/save-location"
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService
@inject SavedLocationService SavedLocationService

<PageTitle>CloudMaps — Set and Save Location</PageTitle>

<div class="page-header">
    <h1>Set, Save, and Restore a Location</h1>
    <p>
        Pan the map so the pin — always shown, fixed to the center of the map — sits over the location you want,
        then save it in browser storage. This demo shows a complete pattern you can reuse in your app
        (center-pin selection + persistence service).
    </p>
</div>

<DemoResultCodeTabs>
    <ResultContent>
        <div class="card">
    <h2 class="card-title">📍 Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  ShowSearchBox="true"
                  ShowCurrentLocationButton="true"
                  ScrollZoomInteraction="false"
                  AddMarkerTrigger="MarkerAddTrigger.CenterPin"
                  OnMapReady="HandleMapReady"
                  OnCenterPinChanged="HandleCenterPinChanged"
                  OnSearchResultSelected="HandleSearchResultSelected"
                  @ref="_map" />
    </div>

    <div class="toolbar" style="margin-top: 1rem;">
        <button class="primary" @onclick="SaveSelectedLocation" disabled="@(!_selectedCoordinate.HasValue || _isSaving)">@(_isSaving ? "Saving…" : "Save Selected")</button>
        <button @onclick="RestoreSavedLocation" disabled="@(_savedLocation is null)">Restore Saved</button>
        <button @onclick="ClearSavedLocation" disabled="@(_savedLocation is null)">Clear Saved</button>
        <span class="badge" style="@(_statusIsError ? "background:#fde7e9;color:#a80000;" : "")">@_status</span>
    </div>
        </div>

        <div class="card">
    <h2 class="card-title">Selection</h2>
    @if (_selectedCoordinate is { } selected)
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px;">
            <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                <div style="font-weight: 600; margin-bottom: 8px; color: #0078d4;">Current Selection</div>
                <div><strong>Latitude:</strong> @selected.Latitude.ToString("F6")</div>
                <div><strong>Longitude:</strong> @selected.Longitude.ToString("F6")</div>
            </div>
        </div>
    }
    else
    {
        <p style="color: #999; font-size: 13px;">Pan the map to position the pin over a location.</p>
    }
        </div>

        <div class="card">
    <h2 class="card-title">Saved Location</h2>
    @if (_savedLocation is { } saved)
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px;">
            <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 12px;">
                <div style="font-weight: 600; margin-bottom: 8px; color: #107c10;">Persisted Value</div>
                @if (!string.IsNullOrWhiteSpace(saved.Label))
                {
                    <div><strong>Label:</strong> @saved.Label</div>
                }
                <div><strong>Latitude:</strong> @saved.Latitude.ToString("F6")</div>
                <div><strong>Longitude:</strong> @saved.Longitude.ToString("F6")</div>
            </div>
        </div>
    }
    else
    {
        <p style="color: #999; font-size: 13px;">No location saved yet.</p>
    }
        </div>
    </ResultContent>

    <CodeContent>
        <div class="card">
            <h2 class="card-title">How to implement in your app</h2>
            <p style="font-size: 13px; color: #666; margin-top: 0;">
                Register a persistence service, use <code>MarkerAddTrigger.CenterPin</code> for an always-visible
                pin, handle <code>OnCenterPinChanged</code>, and save the coordinate.
            </p>

            <h3 style="margin-top: 0;">1) Component usage</h3>
            <pre class="code-snippet"><code>@_usageSnippet</code></pre>

            <h3>2) Service registration (Program.cs)</h3>
            <pre class="code-snippet"><code>builder.Services.AddScoped&lt;SavedLocationService&gt;();</code></pre>
        </div>
    </CodeContent>
</DemoResultCodeTabs>

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(37.7749, -122.4194, 11);

    private MapCoordinate? _selectedCoordinate;
    private SavedLocation? _savedLocation;
    private bool _mapReady;
    private bool _isSaving;
    private bool _statusIsError;
    private string _status = "Pan the map to move the pin over a location";

    private readonly string _usageSnippet = """
<AzureMap Height=\"500px\"
          Width=\"100%\"
          SubscriptionKey=\"@GetSubscriptionKey()\"
          ShowCurrentLocationButton=\"true\"
          ScrollZoomInteraction=\"false\"
          AddMarkerTrigger=\"MarkerAddTrigger.CenterPin\"
          OnCenterPinChanged=\"HandleCenterPinChanged\"
          @ref=\"_map\" />

@code {
    private AzureMap? _map;
    private MapCoordinate? _selectedCoordinate;

    // Fires whenever the fixed, always-visible pin's coordinate changes —
    // i.e. whenever the map is panned, since the pin stays screen-centered.
    private Task HandleCenterPinChanged(MapCoordinate point)
    {
        _selectedCoordinate = point;
        return Task.CompletedTask;
    }
}
""";

    protected override async Task OnInitializedAsync()
    {
        _savedLocation = await SavedLocationService.InitializeAsync();

        if (_savedLocation is not null)
        {
            _selectedCoordinate = new MapCoordinate(_savedLocation.Latitude, _savedLocation.Longitude);
            _status = "Saved location loaded";
        }
    }

    private async Task HandleMapReady()
    {
        _mapReady = true;

        if (_selectedCoordinate is { } selected)
            await _map!.SetCenterAsync(selected.Latitude, selected.Longitude, 13);
    }

    /// <summary>
    /// The pin is always visible and screen-centered (<see cref="MarkerAddTrigger.CenterPin"/>);
    /// this fires whenever panning (or a search/locate fly-to) settles it over a new coordinate.
    /// </summary>
    private Task HandleCenterPinChanged(MapCoordinate coordinate)
    {
        _selectedCoordinate = coordinate;
        _statusIsError = false;
        _status = "Location selected — click Save Selected to persist it";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleSearchResultSelected(MapSearchResult result)
    {
        // The map already flew to the result; the pin's own OnCenterPinChanged
        // will fire once the camera settles and update _selectedCoordinate.
        _statusIsError = false;
        _status = $"Flew to \"{result.Address}\" — adjust the pin, then save";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task SaveSelectedLocation()
    {
        if (!_selectedCoordinate.HasValue || _isSaving)
            return;

        _isSaving = true;
        _statusIsError = false;
        _status = "Saving…";
        StateHasChanged();

        try
        {
            var selected = _selectedCoordinate.Value;
            var location = new SavedLocation(selected.Latitude, selected.Longitude, "Pinned location");
            var saved = await SavedLocationService.SaveAsync(location);

            if (saved)
            {
                _savedLocation = location;
                _status = "Location saved";
            }
            else
            {
                _statusIsError = true;
                _status = "Save failed — browser storage may be unavailable (e.g. private browsing)";
            }
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task RestoreSavedLocation()
    {
        if (_savedLocation is null || _map is null)
            return;

        var selected = new MapCoordinate(_savedLocation.Latitude, _savedLocation.Longitude);
        _statusIsError = false;
        _status = "Saved location restored";

        // Recentering the camera is enough — the fixed pin follows the map
        // center automatically, and OnCenterPinChanged updates _selectedCoordinate.
        await _map.SetCenterAsync(selected.Latitude, selected.Longitude, 15);
        StateHasChanged();
    }

    private async Task ClearSavedLocation()
    {
        await SavedLocationService.ClearAsync();
        _savedLocation = null;
        _statusIsError = false;
        _status = "Saved location cleared";
        StateHasChanged();
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }
}
