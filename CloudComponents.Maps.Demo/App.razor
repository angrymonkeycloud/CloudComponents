@using CloudComponents.Maps.Demo.Services
@inject AzureMapsConfigurationService ConfigService

<ConfigurationModal IsVisible="@ShowConfigurationModal" 
                    OnClose="@HideConfigurationModal"
                    OnConfigurationSaved="@HandleConfigurationSaved" />

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private bool ShowConfigurationModal = false;

    protected override async Task OnInitializedAsync()
    {
        await ConfigService.InitializeAsync();

        // Show configuration modal if no key is stored
        if (!ConfigService.IsConfigured)
        {
            ShowConfigurationModal = true;
        }
    }

    private async Task HideConfigurationModal()
    {
        // Only hide if key is configured
        if (ConfigService.IsConfigured)
        {
            ShowConfigurationModal = false;
            StateHasChanged();
        }
    }

    private async Task HandleConfigurationSaved(string key)
    {
        ShowConfigurationModal = false;
        StateHasChanged();
    }
}
