@page "/popup"

<PageTitle>Popup &amp; Dialog — Cloud Components Demo</PageTitle>

<div class="page-header">
    <h1>Popup &amp; Dialog</h1>
    <p>
        <code>PopupComp</code> is a lightweight overlay modal with browser-history integration.
        <code>Dialog</code> builds on top of it and adds a typed button list with callbacks.
    </p>
</div>

<!-- ── Popup ──────────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Popup</h2>
    <p class="card-subtitle">
        Configure the size and header-close options, then open the popup to observe its behavior.
        Pressing the browser back button or clicking outside (when allowed) also closes it.
    </p>

    <div class="toolbar">
        <label>Size</label>
        <select class="input" @bind="_popupSize">
            <option value="_small">Small</option>
            <option value="_medium">Medium</option>
            <option value="_large">Large</option>
            <option value="_xlarge">XLarge</option>
            <option value="_form">Form</option>
        </select>

        <label>
            <input type="checkbox" @bind="_popupHeaderClose" />
            Header close button
        </label>

        <label>
            <input type="checkbox" @bind="_popupPreventClick" />
            Prevent close on overlay click
        </label>

        <button class="btn btn-primary" @onclick="OpenPopup">Open Popup</button>
    </div>

    <PopupComp @ref="_popup"
               Title="Popup Example"
               Size="@_popupSize"
               HeaderClose="@_popupHeaderClose"
               PreventCloseOnClick="@_popupPreventClick"
               IsOpen="@_popupOpen"
               IsOpenChanged="OnPopupIsOpenChanged">
        <p>This content is rendered inside the popup body slot.</p>
        <p>Try resizing the window — the popup adapts responsively.</p>
    </PopupComp>

    <div class="log">
        @if (_popupLog.Count == 0)
        {
            <span class="log-empty">No events yet — open the popup to start.</span>
        }
        @foreach (var entry in _popupLog)
        {
            <div class="log-line"><span class="log-time">@entry.Time</span>@entry.Message</div>
        }
    </div>
</div>

<!-- ── Dialog ─────────────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Dialog</h2>
    <p class="card-subtitle">
        <code>Dialog</code> uses <code>PopupComp</code> internally. Pass a <code>List&lt;DialogButton&gt;</code>
        with optional <code>OnReply</code> callbacks and <code>AutoClose</code> control.
    </p>

    <div class="toolbar">
        <button class="btn btn-primary" @onclick="OpenDialog">Open Confirmation Dialog</button>
    </div>

    <Dialog @ref="_dialog"
            Title="Confirm Action"
            Buttons="@_dialogButtons"
            OnOpened="OnDialogOpened"
            OnClosed="OnDialogClosed">
        Are you sure you want to proceed? This action cannot be undone.
    </Dialog>

    @if (_dialogReply is not null)
    {
        <p>Last reply: <strong>@_dialogReply</strong></p>
    }

    <div class="log">
        @if (_dialogLog.Count == 0)
        {
            <span class="log-empty">No events yet — open the dialog to start.</span>
        }
        @foreach (var entry in _dialogLog)
        {
            <div class="log-line"><span class="log-time">@entry.Time</span>@entry.Message</div>
        }
    </div>
</div>

@code {
    // ── Popup state ────────────────────────────────────────────────────────
    private PopupComp? _popup;
    private bool _popupOpen;
    private string _popupSize = "_small";
    private bool _popupHeaderClose = true;
    private bool _popupPreventClick = false;
    private List<LogEntry> _popupLog = new();

    private async Task OpenPopup()
    {
        LogPopup("Calling popup.Open()");
        await _popup!.Open();
    }

    private void OnPopupIsOpenChanged(bool v)
    {
        _popupOpen = v;
        LogPopup($"IsOpen changed → {v}");
        StateHasChanged();
    }

    private void LogPopup(string msg) =>
        _popupLog.Insert(0, new LogEntry(DateTime.Now.ToString("HH:mm:ss.fff"), msg));

    // ── Dialog state ───────────────────────────────────────────────────────
    private Dialog? _dialog;
    private string? _dialogReply;
    private List<LogEntry> _dialogLog = new();
    private List<DialogButton> _dialogButtons = new();

    protected override void OnInitialized()
    {
        _dialogButtons = new List<DialogButton>
        {
            new DialogButton
            {
                Text = "Confirm",
                AutoClose = true,
                OnReply = OnConfirmReply
            },
            new DialogButton
            {
                Text = "Cancel",
                AutoClose = true,
                OnReply = OnCancelReply
            }
        };
    }

    private void OnConfirmReply()
    {
        _dialogReply = "Confirmed";
        LogDialog("Button clicked: Confirm");
        StateHasChanged();
    }

    private void OnCancelReply()
    {
        _dialogReply = "Cancelled";
        LogDialog("Button clicked: Cancel");
        StateHasChanged();
    }

    private void OnDialogOpened() => LogDialog("Dialog opened");
    private void OnDialogClosed() => LogDialog("Dialog closed");

    private async Task OpenDialog()
    {
        LogDialog("Calling dialog.Open()");
        await _dialog!.Open();
    }

    private void LogDialog(string msg) =>
        _dialogLog.Insert(0, new LogEntry(DateTime.Now.ToString("HH:mm:ss.fff"), msg));
}
