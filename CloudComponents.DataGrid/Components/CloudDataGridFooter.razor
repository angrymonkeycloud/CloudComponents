@namespace AngryMonkey.CloudComponents.DataGrid.Components
@using AngryMonkey.CloudComponents.DataGrid.Models

@*
    CloudDataGridFooter — range info and page navigation bar rendered below a CloudDataGrid table.

    Markup follows the Angry Monkey CSS naming convention; styles live inside
    CloudDataGridFooter.razor.less / CloudDataGridFooter.razor.css.

    This component is purely presentational: all state and callbacks are supplied
    as parameters from the parent CloudDataGrid.
*@

<footer class="cloudgridfooter">
    <nav class="cloudgridfooter-pager @(ShowPager ? string.Empty : "_hidden")">
        <button type="button" title="Previous page" disabled="@(!CanGoPrevious)" @onclick="PreviousPageAsync">
            <svg viewBox="0 0 50 50"><polyline points="36.8,1.5 13.3,24.8 36.8,48" /></svg>
        </button>

        <span>@PageLabel</span>

        <button type="button" title="Next page" disabled="@(!CanGoNext)" @onclick="NextPageAsync">
            <svg viewBox="0 0 50 50"><polyline points="13.3,48.1 36.8,24.8 13.3,1.5" /></svg>
        </button>
    </nav>

    <div class="cloudgridfooter-info">
        <span>@RangeLabel</span>

        @if (SelectedCount > 0)
        {
            <span class="cloudgridfooter-selected">@SelectedCount selected</span>
        }
    </div>
</footer>
