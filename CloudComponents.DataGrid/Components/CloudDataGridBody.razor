@namespace AngryMonkey.CloudComponents.DataGrid.Components
@using AngryMonkey.CloudComponents.DataGrid.Models
@using Microsoft.AspNetCore.Components.Web.Virtualization

@*
    CloudDataGridBody — table head, rows, load-more button and the pointer-capture shields
    for column resizing and row drag-and-drop.

    Markup follows the Angry Monkey CSS naming convention; styles live inside
    CloudDataGridBody.razor.less / CloudDataGridBody.razor.css.

    All behavior lives in CloudDataGridBody.razor.cs.
*@

<div class="cloudgrid-table" style="@TableStyle">

    <div class="cloudgrid-head">

        @if (AllowReordering)
        {
            <div class="cloudgrid-draghandle @UtilityPinnedClass" style="@UtilityPinnedStyle(0)"></div>
        }

        @if (AllowSelection)
        {
            <div class="cloudgrid-check @UtilityPinnedClass" style="@UtilityPinnedStyle(AllowReordering ? 28 : 0)">
                <input type="checkbox" title="Select all" checked="@AllRowsSelected" @onchange="ToggleSelectAllAsync" />
            </div>
        }

        @for (int i = 0; i < Columns.Count; i++)
        {
            int columnIndex = i;
            CloudDataGridColumn column = Columns[columnIndex];

            <div class="cloudgrid-headcell @HeadCellClasses(columnIndex)"
                 style="@HeadCellStyle(columnIndex)"
                 @onclick="() => SortByAsync(columnIndex)">

                <span>@column.Label</span>

                @if (_sortIndex == columnIndex)
                {
                    <SortIcon Down="@(_sortDirection == CloudDataGridSortDirection.Descending)" />
                }

                @if (column.Resizable)
                {
                    <div class="cloudgrid-resizer"
                         @onclick:stopPropagation
                         @onpointerdown="e => BeginResize(columnIndex, e)"
                         @onpointerdown:preventDefault
                         @onpointerdown:stopPropagation></div>
                }
            </div>
        }
    </div>

    <div class="cloudgrid-body @BodyClasses" style="@BodyStyle">

        @if (IsLoading)
        {
            <div class="cloudgrid-status _loading">@LoadingText</div>
        }
        else if (IsSearching)
        {
            <div class="cloudgrid-status _searching">@SearchingText</div>
        }
        else if (!string.IsNullOrEmpty(Message))
        {
            <div class="cloudgrid-status _message">@Message</div>
        }
        else if (Data != null)
        {
            @if (PagingMode == CloudDataGridPagingMode.InfiniteScroll)
            {
                @* Blazor's built-in Virtualize detects scrolling near the end of
                   the loaded rows and asks the provider for the missing range,
                   which triggers loading the next page — no custom JavaScript. *@
                <Virtualize @ref="_virtualize" TItem="CloudDataGridDisplayItem" ItemsProvider="ProvideRowsAsync" ItemSize="@((float)EffectiveRowHeight)" OverscanCount="5">
                    <ItemContent>@RenderDisplayItem(context)</ItemContent>
                    <Placeholder>
                        <div class="cloudgrid-row _placeholder @(HasRowNotes ? "_with-note" : null)"></div>
                    </Placeholder>
                </Virtualize>
            }
            else
            {
                foreach (CloudDataGridDisplayItem item in DisplayItems)
                {
                    @RenderDisplayItem(item)
                }

                @if (PagingMode == CloudDataGridPagingMode.LoadMore && HasMoreRows)
                {
                    <button type="button" class="cloudgrid-loadmore" disabled="@_loadMorePending" @onclick="LoadMoreAsync">
                        @(_loadMorePending ? LoadingText : LoadMoreText)
                    </button>
                }
            }
        }
    </div>

    @if (ColumnFooterRows.Count > 0)
    {
        <div class="cloudgrid-columnfooters @(FixedColumnFooter ? "_fixed" : null)">
            @foreach (CloudDataGridFooterRow footerRow in ColumnFooterRows)
            {
                <div class="cloudgrid-columnfooter @footerRow.CssClass" style="@footerRow.Style" @attributes="footerRow.Attributes">
                    @if (AllowReordering)
                    {
                        <div class="cloudgrid-draghandle @UtilityPinnedClass" style="@UtilityPinnedStyle(0)"></div>
                    }
                    @if (AllowSelection)
                    {
                        <div class="cloudgrid-check @UtilityPinnedClass" style="@UtilityPinnedStyle(AllowReordering ? 28 : 0)"></div>
                    }
                    @FooterCells(footerRow)
                </div>
            }
        </div>
    }
</div>

@if (_resizeIndex.HasValue)
{
    @* Transparent overlay capturing pointer events while a column is being
       resized, so dragging works without any JavaScript interop. *@
    <div class="cloudgrid-shield"
         @onpointermove="ResizeMove"
         @onpointerup="EndResize"
         @onpointercancel="EndResize"
         @onpointerleave="EndResize"></div>
}

@if (_dragRowId.HasValue)
{
    @* Same trick for row drag & drop: the shield tracks pointer movement
       while a row is being re-arranged — no JavaScript interop needed. *@
    <div class="cloudgrid-shield _rowdrag"
         @onpointermove="RowDragMove"
         @onpointerup="EndRowDrag"
         @onpointercancel="EndRowDrag"
         @onpointerleave="EndRowDrag"></div>
}

@code {
    // Markup-only helpers stay in the .razor file; all behavior lives in CloudDataGridBody.razor.cs.

    private RenderFragment<CloudDataGridDisplayItem> RenderDisplayItem => item => @<text>
        @if (item.Category is not null)
        {
            @RenderCategory(item.Category)
        }
        else if (item.Row is not null)
        {
            @RenderRow(item.Row)
        }
    </text>;

    private RenderFragment<CloudDataGridCategoryContext> RenderCategory => category => @<text>
        <div class="cloudgrid-category @(category.IsExpanded ? "_expanded" : "_collapsed")">
            @if (AllowCategoryCollapse)
            {
                <button type="button"
                        class="cloudgrid-categorycontent"
                        aria-expanded="@(category.IsExpanded ? "true" : "false")"
                        @onclick="() => ToggleCategoryAsync(category)">
                    <span class="cloudgrid-categorychevron" aria-hidden="true">&#x25B6;</span>
                    @if (CategoryHeaderTemplate is not null)
                    {
                        @CategoryHeaderTemplate(category)
                    }
                    else
                    {
                        <strong>@category.Label</strong>
                        <span class="cloudgrid-categorycount">@category.VisibleRowCount</span>
                    }
                </button>
            }
            else
            {
                <div class="cloudgrid-categorycontent">
                    @if (CategoryHeaderTemplate is not null)
                    {
                        @CategoryHeaderTemplate(category)
                    }
                    else
                    {
                        <strong>@category.Label</strong>
                        <span class="cloudgrid-categorycount">@category.VisibleRowCount</span>
                    }
                </div>
            }
        </div>
    </text>;

    private RenderFragment<CloudDataGridRow> RenderRow => row => @<text>
        <div class="cloudgrid-row @RowClasses(row)" style="@row.Style" data-id="@row.Id" @attributes="row.Attributes">

          <div class="cloudgrid-rowmain" style="@row.Style">

            @if (AllowReordering)
            {
                <div class="cloudgrid-draghandle @UtilityPinnedClass" style="@UtilityPinnedStyle(0)"
                     title="Drag to re-arrange"
                     @onpointerdown="e => BeginRowDrag(row, e)"
                     @onpointerdown:preventDefault
                     @onpointerdown:stopPropagation>
                  <DragIcon />
                </div>
            }

            @if (AllowSelection)
            {
                <div class="cloudgrid-check @UtilityPinnedClass" style="@UtilityPinnedStyle(AllowReordering ? 28 : 0)">
                    <input type="checkbox" checked="@IsRowSelected(row)" @onchange="() => ToggleRowAsync(row)" />
                </div>
            }

            @if (!string.IsNullOrEmpty(row.Link))
            {
                <a href="@row.Link" target="@LinkTarget">@RowCells(row)</a>
            }
            else
            {
                @RowCells(row)
            }

            @{
                List<CloudDataGridAction> rowActions = [.. RowVisibleActions(row)];
            }

            @if (rowActions.Count > 0)
            {
                <div class="cloudgrid-rowactions" @onclick:stopPropagation @onclick:preventDefault>
                    @foreach (CloudDataGridAction action in rowActions)
                    {
                        @RenderRowAction((action, row))
                    }
                </div>
            }
          </div>

          @if (HasRowNotes)
          {
              <div class="cloudgrid-rownote @row.NoteCssClass" style="@row.NoteStyle">@row.Note</div>
          }
        </div>
    </text>;

    /// <summary>Renders a single action inside a row's action cell.</summary>
    private RenderFragment<(CloudDataGridAction Action, CloudDataGridRow Row)> RenderRowAction => ctx => @<text>
        @if (ctx.Action.Type == CloudDataGridActionType.Link)
        {
            <a class="cloudgrid-action @ctx.Action.CssClass"
               href="@ctx.Action.Href"
               target="@ctx.Action.Target"
               title="@(ctx.Action.Tooltip ?? ctx.Action.Text)">
                @RowActionIconAndText(ctx.Action)
            </a>
        }
        else if (ctx.Action.Type == CloudDataGridActionType.Button)
        {
            <button type="button"
                    class="cloudgrid-action @ctx.Action.CssClass"
                    title="@(ctx.Action.Tooltip ?? ctx.Action.Text)"
                    @onclick="() => RowActionClickAsync(ctx.Action, ctx.Row)"
                    @onclick:stopPropagation
                    @onclick:preventDefault>
                @RowActionIconAndText(ctx.Action)
            </button>
        }
        else if (ctx.Action.Type == CloudDataGridActionType.Element)
        {
            bool isActive = IsRowElementActive(ctx.Row, ctx.Action);

            @if (isActive && ctx.Action.ChildContent != null)
            {
                @ctx.Action.ChildContent
                <button type="button"
                        class="cloudgrid-action _cancel"
                        @onclick="CancelRowElementAsync"
                        @onclick:stopPropagation
                        @onclick:preventDefault>
                    cancel
                </button>
            }
            else
            {
                <button type="button"
                        class="cloudgrid-action @ctx.Action.CssClass"
                        title="@(ctx.Action.Tooltip ?? ctx.Action.Text)"
                        @onclick="() => ToggleRowElementAsync(ctx.Row, ctx.Action)"
                        @onclick:stopPropagation
                        @onclick:preventDefault>
                    @RowActionIconAndText(ctx.Action)
                </button>
            }
        }
    </text>;

    private RenderFragment RowActionIconAndText(CloudDataGridAction action) => @<text>
        @{
            string? text = string.IsNullOrWhiteSpace(action.Text) ? action.Tooltip : action.Text;
        }
        @if (action.Icon != null)
        {
            @action.Icon
        }
        else if (!string.IsNullOrEmpty(action.IconSvg))
        {
            @((MarkupString)action.IconSvg)
        }
        @if (!string.IsNullOrWhiteSpace(text))
        {
            <span>@text</span>
        }
    </text>;

    private RenderFragment<CloudDataGridRow> RowCells => row => @<text>
        @for (int c = 0; c < Columns.Count; c++)
        {
            object? source = row.Cells.ElementAtOrDefault(c);
            CloudDataGridCell? cell = source as CloudDataGridCell;
            object? value = cell?.Value ?? source;
            CloudDataGridColumn column = Columns[c];
            CloudDataGridCellContext context = CellContext(row, column, c, cell, value, false);

            <div class="cloudgrid-cell @CellClasses(column, cell)" style="@CellStyle(c, cell)" @attributes="cell?.Attributes">
                @if (cell?.Template is not null)
                {
                    @cell.Template(context)
                }
                else if (column.CellTemplate is not null)
                {
                    @column.CellTemplate(context)
                }
                else if (column.IsImage && value is string imageUrl && !string.IsNullOrWhiteSpace(imageUrl))
                {
                    <img src="@imageUrl" alt="" loading="lazy" />
                }
                else
                {
                    <span>@(value ?? EmptyCellText)</span>
                }
            </div>
        }
    </text>;

    private RenderFragment<CloudDataGridFooterRow> FooterCells => footerRow => @<text>
        @for (int c = 0; c < Columns.Count; c++)
        {
            object? source = footerRow.Cells.ElementAtOrDefault(c);
            CloudDataGridCell? cell = source as CloudDataGridCell;
            object? value = cell?.Value ?? source;
            CloudDataGridColumn column = Columns[c];
            CloudDataGridCellContext context = CellContext(null, column, c, cell, value, true);

            <div class="cloudgrid-cell @CellClasses(column, cell)" style="@CellStyle(c, cell)" @attributes="cell?.Attributes">
                @if (cell?.Template is not null)
                {
                    @cell.Template(context)
                }
                else
                {
                    <span>@(value ?? string.Empty)</span>
                }
            </div>
        }
    </text>;
}
