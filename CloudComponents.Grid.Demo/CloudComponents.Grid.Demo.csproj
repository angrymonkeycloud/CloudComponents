<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<AssemblyName>CloudComponents.Grid.Demo</AssemblyName>
		<RootNamespace>CloudComponents.Grid.Demo</RootNamespace>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<Configurations>Debug;Release;Release_Server</Configurations>
		<Version>1.0.0</Version>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.8" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.8" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\CloudComponents.Grid\CloudComponents.Grid.csproj" />
		<ProjectReference Include="..\CloudComponents.Icons\CloudComponents.Icons.csproj" />
	</ItemGroup>

</Project>
