@page "/paging"
@inject SampleDataService Data

<PageTitle>CloudGrid — Paging Modes</PageTitle>

<div class="page-header">
    <h1>Paging Modes</h1>
    <p>
        The same grid and data provider, switchable across all three paging modes. In
        <strong>Pages</strong> mode each page replaces the rows and the footer shows previous/next
        arrows. In <strong>Load more</strong> mode a button appends the next page. In
        <strong>Infinite scroll</strong> mode the next page loads automatically as you scroll near
        the end. The grid manages appending internally — the data provider just returns the
        requested page.
    </p>
</div>

<div class="card">
    <div class="toolbar">
        <label>Paging mode:</label>
        <div class="segmented">
            <button class="@(_mode == CloudGridPagingMode.Pages ? "active" : "")"
                    @onclick="() => SetMode(CloudGridPagingMode.Pages)">Pages</button>
            <button class="@(_mode == CloudGridPagingMode.LoadMore ? "active" : "")"
                    @onclick="() => SetMode(CloudGridPagingMode.LoadMore)">Load more</button>
            <button class="@(_mode == CloudGridPagingMode.InfiniteScroll ? "active" : "")"
                    @onclick="() => SetMode(CloudGridPagingMode.InfiniteScroll)">Infinite scroll</button>
        </div>

        <label style="margin-left:1rem;">Rows per page:</label>
        <select class="input" @bind="_pageSize" @bind:after="ReloadGrid">
            <option value="5">5</option>
            <option value="8">8</option>
            <option value="12">12</option>
        </select>

        <span class="badge">@_mode</span>
    </div>

    <div class="grid-host">
        @* @key forces a fresh grid (re-initialised from page 1) whenever the mode or page size changes. *@
        <CloudGrid @key="_gridKey"
                   Columns="_columns"
                   DataProvider="LoadAsync"
                   PagingMode="_mode"
                   RowHeight="40"
                   RowsPerPage="_pageSize"
                   LoadMoreText="Load more employees" />
    </div>
</div>

@code {
    private CloudGridPagingMode _mode = CloudGridPagingMode.Pages;
    private int _pageSize = 8;
    private int _gridKey;

    private readonly List<CloudGridColumn> _columns =
    [
        new() { Label = "Name", Key = "name", Width = 200 },
        new() { Label = "Email", Key = "email", Width = 250 },
        new() { Label = "Department", Key = "department", Width = 150 },
        new() { Label = "Country", Key = "country", Width = 130 }
    ];

    private void SetMode(CloudGridPagingMode mode)
    {
        if (_mode == mode)
            return;

        _mode = mode;
        ReloadGrid();
    }

    private void ReloadGrid() => _gridKey++;

    private async Task<CloudGridDataResult?> LoadAsync(CloudGridDataRequest request)
        => await Data.QueryAsync(request, ToRow);

    private static CloudGridRow ToRow(Person p) => new()
    {
        Id = p.Id,
        Cells = [p.FullName, p.Email, p.Department, p.Country]
    };
}
