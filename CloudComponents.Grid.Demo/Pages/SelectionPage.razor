@page "/selection"
@inject SampleDataService Data
@inject IJSRuntime JS

<PageTitle>CloudGrid — Selection &amp; Actions</PageTitle>

<div class="page-header">
    <h1>Selection &amp; Actions</h1>
    <p>
        Tick the checkboxes (or the header's select-all) to select rows — the selection is two-way
        bound, so the live count below updates instantly. A <strong>bulk</strong> action appears next
        to the title only while rows are selected. The <strong>Export</strong> header action opens a
        dropdown that exports the current page, all matching rows, or the selection as
        <code>.csv</code> by default. Each row exposes <strong>Edit</strong> and <strong>Delete</strong>
        actions; an <code>ActionFilter</code> hides Delete on active employees. Every action click is
        recorded in the event log.
    </p>
</div>

<div class="card">
    <div class="toolbar">
        <span class="badge">Selected: @_selected.Count</span>
        <button class="btn" @onclick="ClearSelection" disabled="@(_selected.Count == 0)">Clear selection</button>
    </div>

    <div class="grid-host">
        <CloudGrid Header="_header"
                   Columns="_columns"
                   DataProvider="LoadAsync"
                   AllowSelection="true"
                   @bind-SelectedRecords="_selected"
                   RowActions="_rowActions"
                   ActionFilter="FilterAction"
                   OnActionClicked="OnAction"
                   RowHeight="40"
                   RowsPerPage="10" />
    </div>
</div>

<div class="card">
    <h2 class="card-title">Event log</h2>
    <p class="card-subtitle">Bulk actions report every selected id; row actions report the single row id.</p>
    @if (_log.Count == 0)
    {
        <div class="log"><span class="log-empty">No actions yet — select rows and use the toolbar, or click a row action.</span></div>
    }
    else
    {
        <div class="log">
            @foreach (var entry in _log)
            {
                <div class="log-line"><span class="log-time">@entry.Time</span>@entry.Message</div>
            }
        </div>
    }
</div>

@code {
    private const string DefaultExportFormat = "csv";

    private List<Guid> _selected = [];
    private List<Person> _currentPagePeople = [];
    private CloudGridDataRequest? _lastRequest;
    private readonly List<(string Time, string Message)> _log = [];
    private readonly string _exportFormat = DefaultExportFormat;

    private readonly CloudGridHeaderOptions _header = new()
    {
        Label = "Team",
        AllowSearch = true,
        AllowRefresh = true
    };

    private readonly List<CloudGridColumn> _columns =
    [
        new() { Label = "Photo", IsImage = true, Sortable = false, Resizable = false, Width = 56 },
        new() { Label = "Name", Key = "name", Width = 190 },
        new() { Label = "Department", Key = "department", Width = 150 },
        new() { Label = "Country", Key = "country", Width = 130 },
        new() { Label = "Status", Key = "active", Width = 110 }
    ];

    private List<CloudGridAction> _rowActions = [];

    protected override void OnInitialized()
    {
        // Bulk header action — only visible while rows are selected.
        _header.Actions =
        [
            new CloudGridAction
            {
                Key = "bulk-deactivate",
                Text = "Deactivate",
                Tooltip = "Deactivate selected",
                ShowOnHeader = false,
                ShowOnBulkHeader = true
            },
            new CloudGridAction
            {
                Key = "export",
                Text = "Export",
                Tooltip = "Export",
                Icon = builder => { builder.OpenComponent<AddIcon>(0); builder.CloseComponent(); },
                Type = CloudGridActionType.Element,
                ChildContent = ExportMenu,
                ShowOnHeader = true
            }
        ];

        // Route header/bulk action clicks to the same log handler used for rows.
        _header.OnActionClicked = EventCallback.Factory.Create<CloudGridActionEventArgs>(this, OnAction);

        _rowActions =
        [
            new CloudGridAction
            {
                Key = "edit",
                Tooltip = "Edit",
                Icon = builder => { builder.OpenComponent<ExpandIcon>(0); builder.CloseComponent(); },
                ShowOnHeader = false,
                ShowOnRow = true
            },
            new CloudGridAction
            {
                Key = "delete",
                Tooltip = "Delete",
                Icon = builder => { builder.OpenComponent<CrossIcon>(0); builder.CloseComponent(); },
                CssClass = "_danger",
                ShowOnHeader = false,
                ShowOnRow = true
            }
        ];
    }

    private async Task<CloudGridDataResult?> LoadAsync(CloudGridDataRequest request)
    {
        _lastRequest = request;
        List<Person> currentPage = [];

        CloudGridDataResult result = await Data.QueryAsync(request, person =>
        {
            currentPage.Add(person);
            return ToRow(person);
        });

        _currentPagePeople = currentPage;
        return result;
    }

    private static CloudGridRow ToRow(Person p) => new()
    {
        Id = p.Id,
        Cells =
        [
            p.AvatarUrl,
            p.FullName,
            p.Department,
            p.Country,
            p.IsActive ? "Active" : "Inactive"
        ]
    };

    // Hide Delete on active employees to demonstrate per-row action filtering.
    private bool FilterAction(CloudGridRow row, CloudGridAction action)
    {
        if (action.Key != "delete")
            return true;

        Person? person = Data.GetByIds([row.Id]).FirstOrDefault();
        return person is null || !person.IsActive;
    }

    private void OnAction(CloudGridActionEventArgs args)
    {
        string ids = args.RecordIds.Count switch
        {
            0 => "(no rows)",
            1 => ShortId(args.RecordIds[0]),
            _ => $"{args.RecordIds.Count} rows"
        };

        AddLog($"Action '{args.Action.Key}' → {ids}");
    }

    private async Task ExportCurrentPageAsync()
    {
        await DownloadCsvAsync(_currentPagePeople, "current-page");
    }

    private async Task ExportAllAsync()
    {
        if (_lastRequest == null)
            return;

        List<Person> all = [];

        await Data.QueryAsync(new CloudGridDataRequest
        {
            Page = 1,
            PageSize = Data.Count,
            Search = _lastRequest.Search,
            Sort = _lastRequest.Sort,
            IsAppend = false,
            Total = _lastRequest.Total
        }, person =>
        {
            all.Add(person);
            return ToRow(person);
        }, simulatedDelayMs: 0);

        await DownloadCsvAsync(all, "all-records");
    }

    private async Task ExportSelectionAsync()
    {
        await DownloadCsvAsync(Data.GetByIds(_selected), "selection");
    }

    private async Task DownloadCsvAsync(IEnumerable<Person> people, string scope)
    {
        List<Person> records = people.ToList();
        string csv = BuildCsv(records);
        string fileName = $"cloudgrid-{scope}-{DateTime.Now:yyyyMMdd-HHmmss}.{_exportFormat}";

        await JS.InvokeVoidAsync("cloudGridDemo.downloadTextFile", fileName, csv, "text/csv;charset=utf-8");
        AddLog($"Exported {records.Count} row(s) as {_exportFormat} ({scope})");
    }

    private static string BuildCsv(IEnumerable<Person> people)
    {
        static string Csv(string? value) => $"\"{(value ?? string.Empty).Replace("\"", "\"\"")}\"";

        List<string> lines =
        [
            "Name,Email,Department,Country,Status"
        ];

        lines.AddRange(people.Select(p => string.Join(",",
            Csv(p.FullName),
            Csv(p.Email),
            Csv(p.Department),
            Csv(p.Country),
            Csv(p.IsActive ? "Active" : "Inactive"))));

        return string.Join(Environment.NewLine, lines);
    }

    private RenderFragment ExportMenu => @<div class="export-menu">
        <div class="export-menu-note">Default format: .@_exportFormat</div>
        <button type="button" class="btn" @onclick="ExportCurrentPageAsync">Export current page</button>
        <button type="button" class="btn" @onclick="ExportAllAsync">Export all</button>
        @if (_selected.Count > 0)
        {
            <button type="button" class="btn" @onclick="ExportSelectionAsync">Export selection (@_selected.Count)</button>
        }
    </div>;

    private void ClearSelection()
    {
        _selected = [];
        AddLog("Selection cleared");
    }

    private void AddLog(string message)
    {
        _log.Insert(0, (DateTime.Now.ToString("HH:mm:ss"), message));
        if (_log.Count > 25)
            _log.RemoveAt(_log.Count - 1);
    }

    private static string ShortId(Guid id) => id.ToString()[..8];
}
