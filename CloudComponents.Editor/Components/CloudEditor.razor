@namespace AngryMonkey.CloudComponents.Editor.Components
@using AngryMonkey.CloudComponents.Editor.Models

<div class="cloudeditor @(_isFullscreen ? "_fullscreen" : null) @(_isCodeView ? "_codeview" : null) @(ReadOnly ? "_readonly" : null)">

    <div class="cloudeditor-toolbar" role="toolbar" aria-label="Editor toolbar">

        @if (Toolbar.UndoRedo)
        {
            <div class="cloudeditor-group">
                @ToolbarButton(@<EditorUndoIcon />, "Undo (Ctrl+Z)", UndoAsync)
                @ToolbarButton(@<EditorRedoIcon />, "Redo (Ctrl+Y)", RedoAsync)
            </div>
        }

        @if (Toolbar.Headings)
        {
            <div class="cloudeditor-group">
                <select class="cloudeditor-select" title="Block format" aria-label="Block format"
                        value="@CurrentBlockValue" disabled="@_commandsDisabled" @onchange="HandleBlockFormatChangedAsync">
                    @foreach ((string value, string label) in BlockFormatChoices)
                    {
                        <option value="@value">@label</option>
                    }
                </select>
            </div>
        }

        @if (Toolbar.BasicFormatting)
        {
            <div class="cloudeditor-group">
                @ToolbarButton(@<EditorBoldIcon />, "Bold (Ctrl+B)", () => ExecAsync("bold"), _selectionState.Bold)
                @ToolbarButton(@<EditorItalicIcon />, "Italic (Ctrl+I)", () => ExecAsync("italic"), _selectionState.Italic)
                @ToolbarButton(@<EditorUnderlineIcon />, "Underline (Ctrl+U)", () => ExecAsync("underline"), _selectionState.Underline)
                @ToolbarButton(@<EditorStrikethroughIcon />, "Strikethrough", () => ExecAsync("strikeThrough"), _selectionState.Strikethrough)
            </div>
        }

        @if (Toolbar.Script)
        {
            <div class="cloudeditor-group">
                @ToolbarButton(@<EditorSubscriptIcon />, "Subscript", () => ExecAsync("subscript"), _selectionState.Subscript)
                @ToolbarButton(@<EditorSuperscriptIcon />, "Superscript", () => ExecAsync("superscript"), _selectionState.Superscript)
            </div>
        }

        @if (Toolbar.InlineCode || Toolbar.TextColor || Toolbar.HighlightColor)
        {
            <div class="cloudeditor-group">
                @if (Toolbar.InlineCode)
                {
                    @ToolbarButton(@<EditorInlineCodeIcon />, "Inline code", ToggleInlineCodeAsync, _selectionState.InlineCode)
                }
                @if (Toolbar.TextColor)
                {
                    <span class="cloudeditor-colorhost">
                        @ToolbarButton(@<EditorTextColorIcon />, "Text color", () => ToggleColorPickerAsync("text"), _openColorPicker == "text")
                        @if (_openColorPicker == "text")
                        {
                            @ColorPopover("foreColor")
                        }
                    </span>
                }
                @if (Toolbar.HighlightColor)
                {
                    <span class="cloudeditor-colorhost">
                        @ToolbarButton(@<EditorHighlightIcon />, "Highlight color", () => ToggleColorPickerAsync("highlight"), _openColorPicker == "highlight")
                        @if (_openColorPicker == "highlight")
                        {
                            @ColorPopover("hiliteColor")
                        }
                    </span>
                }
            </div>
        }

        @if (Toolbar.Alignment)
        {
            <div class="cloudeditor-group">
                @ToolbarButton(@<EditorAlignLeftIcon />, "Align left", () => ExecAsync("justifyLeft"), _selectionState.Alignment == "left")
                @ToolbarButton(@<EditorAlignCenterIcon />, "Align center", () => ExecAsync("justifyCenter"), _selectionState.Alignment == "center")
                @ToolbarButton(@<EditorAlignRightIcon />, "Align right", () => ExecAsync("justifyRight"), _selectionState.Alignment == "right")
                @ToolbarButton(@<EditorAlignJustifyIcon />, "Justify", () => ExecAsync("justifyFull"), _selectionState.Alignment == "justify")
            </div>
        }

        @if (Toolbar.Lists || Toolbar.Indentation)
        {
            <div class="cloudeditor-group">
                @if (Toolbar.Lists)
                {
                    @ToolbarButton(@<EditorListBulletIcon />, "Bulleted list", () => ExecAsync("insertUnorderedList"), _selectionState.UnorderedList)
                    @ToolbarButton(@<EditorListNumberedIcon />, "Numbered list", () => ExecAsync("insertOrderedList"), _selectionState.OrderedList)
                }
                @if (Toolbar.Indentation)
                {
                    @ToolbarButton(@<EditorOutdentIcon />, "Decrease indent", () => ExecAsync("outdent"))
                    @ToolbarButton(@<EditorIndentIcon />, "Increase indent", () => ExecAsync("indent"))
                }
            </div>
        }

        @if (Toolbar.Blockquote || Toolbar.CodeBlock)
        {
            <div class="cloudeditor-group">
                @if (Toolbar.Blockquote)
                {
                    @ToolbarButton(@<EditorBlockquoteIcon />, "Blockquote", () => ToggleBlockAsync("blockquote"), _selectionState.BlockTag == "blockquote")
                }
                @if (Toolbar.CodeBlock)
                {
                    @ToolbarButton(@<EditorCodeBlockIcon />, "Code block", () => ToggleBlockAsync("pre"), _selectionState.BlockTag == "pre")
                }
            </div>
        }

        @if (Toolbar.Link || Toolbar.Image || Toolbar.Video || Toolbar.HorizontalRule)
        {
            <div class="cloudeditor-group">
                @if (Toolbar.Link)
                {
                    @ToolbarButton(@<EditorLinkIcon />, "Insert link (Ctrl+K)", OpenLinkDialogAsync, _selectionState.Link)
                    @ToolbarButton(@<EditorUnlinkIcon />, "Remove link", UnlinkAsync, disabled: _commandsDisabled || !_selectionState.Link)
                }
                @if (Toolbar.Image)
                {
                    @ToolbarButton(@<EditorImageIcon />, "Insert image", OpenImageDialogAsync)
                }
                @if (Toolbar.Video)
                {
                    @ToolbarButton(@<EditorVideoIcon />, "Insert video", OpenVideoDialogAsync)
                }
                @if (Toolbar.HorizontalRule)
                {
                    @ToolbarButton(@<EditorHorizontalRuleIcon />, "Horizontal rule", () => ExecAsync("insertHorizontalRule"))
                }
            </div>
        }

        @if (Toolbar.ClearFormatting)
        {
            <div class="cloudeditor-group">
                @ToolbarButton(@<EditorClearFormatIcon />, "Clear formatting", ClearFormattingAsync)
            </div>
        }

        <div class="cloudeditor-spacer"></div>

        @if (Toolbar.CodeView || Toolbar.Fullscreen)
        {
            <div class="cloudeditor-group">
                @if (Toolbar.CodeView)
                {
                    @ToolbarButton(@<EditorCodeViewIcon />, _isCodeView ? "Design view" : "Code view", ToggleCodeViewAsync, _isCodeView, ReadOnly)
                }
                @if (Toolbar.Fullscreen)
                {
                    @if (_isFullscreen)
                    {
                        @ToolbarButton(@<EditorFullscreenExitIcon />, "Exit fullscreen", ToggleFullscreenAsync, true, false)
                    }
                    else
                    {
                        @ToolbarButton(@<EditorFullscreenIcon />, "Fullscreen", ToggleFullscreenAsync, false, false)
                    }
                }
            </div>
        }
    </div>

    <div class="cloudeditor-body">
        <div @ref="_contentElement"
             class="cloudeditor-content"
             contenteditable="@(ReadOnly || _isCodeView ? "false" : "true")"
             data-placeholder="@Placeholder"
             style="@ContentStyle"
             role="textbox"
             aria-multiline="true"
             aria-label="@(Placeholder ?? "Rich text editor")"
             spellcheck="@Spellcheck"></div>

        @if (_isCodeView)
        {
            <div class="cloudeditor-codeview">
                <textarea class="cloudeditor-code"
                          spellcheck="false"
                          placeholder="HTML source"
                          style="@ContentStyle"
                          @bind="_codeViewText"
                          @bind:event="oninput"
                          @bind:after="HandleCodeViewInputAsync"></textarea>

                <div class="cloudeditor-codebar">
                    <div class="cloudeditor-messages">
                        @if (_codeValidation is not null)
                        {
                            @foreach (CloudEditorHtmlValidationMessage message in _codeValidation.Messages)
                            {
                                <div class="cloudeditor-message @(message.Severity == CloudEditorValidationSeverity.Error ? "_error" : "_warning")">
                                    <strong>@(message.Severity == CloudEditorValidationSeverity.Error ? "Error" : "Warning")</strong>
                                    (@message.Line,@message.Column): @message.Message
                                </div>
                            }

                            @if (_codeValidation.Messages.Count == 0)
                            {
                                <div class="cloudeditor-message _ok">Valid HTML</div>
                            }
                        }
                    </div>

                    <div class="cloudeditor-codeactions">
                        <button type="button" class="cloudeditor-action _secondary" @onclick="CancelCodeViewAsync">Cancel</button>
                        <button type="button" class="cloudeditor-action" disabled="@(_codeValidation?.IsValid != true)" @onclick="ApplyCodeViewAsync">
                            <EditorCheckIcon /> Apply
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (_activeDialog != EditorDialog.None)
    {
        <div class="cloudeditor-overlay" @onclick="CloseDialogAsync"></div>

        <div class="cloudeditor-dialog" role="dialog" aria-modal="true">
            <div class="cloudeditor-dialoghead">
                <span>
                    @(_activeDialog switch
                    {
                        EditorDialog.Link => "Insert link",
                        EditorDialog.Image => "Insert image",
                        EditorDialog.Video => "Insert video",
                        _ => string.Empty
                    })
                </span>
                <button type="button" class="cloudeditor-btn" title="Close" @onclick="CloseDialogAsync"><EditorCloseIcon /></button>
            </div>

            @if (_activeDialog == EditorDialog.Link)
            {
                <div class="cloudeditor-dialogbody">
                    <label class="cloudeditor-field">
                        <span>URL</span>
                        <input type="text" placeholder="https://example.com" @bind="_linkUrl" @bind:event="oninput" />
                    </label>
                    <label class="cloudeditor-field">
                        <span>Text</span>
                        <input type="text" placeholder="Link text (optional)" @bind="_linkText" />
                    </label>
                    <label class="cloudeditor-check">
                        <input type="checkbox" @bind="_linkNewTab" /> Open in new tab
                    </label>
                </div>
                <div class="cloudeditor-dialogfoot">
                    <button type="button" class="cloudeditor-action _secondary" @onclick="CloseDialogAsync">Cancel</button>
                    <button type="button" class="cloudeditor-action" disabled="@string.IsNullOrWhiteSpace(_linkUrl)" @onclick="InsertLinkAsync">Insert</button>
                </div>
            }
            else if (_activeDialog == EditorDialog.Image)
            {
                <div class="cloudeditor-dialogbody">
                    <div class="cloudeditor-tabs">
                        <button type="button" class="@(!_imageUploadMode ? "_active" : null)" @onclick="() => _imageUploadMode = false">From URL</button>
                        <button type="button" class="@(_imageUploadMode ? "_active" : null)" @onclick="() => _imageUploadMode = true">Upload</button>
                    </div>

                    @if (!_imageUploadMode)
                    {
                        <label class="cloudeditor-field">
                            <span>Image URL</span>
                            <input type="text" placeholder="https://example.com/image.png" @bind="_imageUrl" @bind:event="oninput" />
                        </label>
                    }
                    else
                    {
                        <label class="cloudeditor-field">
                            <span>File</span>
                            <InputFile OnChange="HandleImageFileAsync" accept="image/*" />
                        </label>
                        @if (_isUploading)
                        {
                            <div class="cloudeditor-hint">Uploading…</div>
                        }
                        else if (!string.IsNullOrEmpty(_imageUrl))
                        {
                            <div class="cloudeditor-hint">File ready to insert.</div>
                        }
                    }

                    <label class="cloudeditor-field">
                        <span>Alt text</span>
                        <input type="text" placeholder="Description (recommended)" @bind="_imageAlt" />
                    </label>
                    <label class="cloudeditor-field">
                        <span>Width</span>
                        <input type="text" placeholder="e.g. 400 or 50% (optional)" @bind="_imageWidth" />
                    </label>

                    @if (_dialogError is not null)
                    {
                        <div class="cloudeditor-message _error">@_dialogError</div>
                    }
                </div>
                <div class="cloudeditor-dialogfoot">
                    <button type="button" class="cloudeditor-action _secondary" @onclick="CloseDialogAsync">Cancel</button>
                    <button type="button" class="cloudeditor-action" disabled="@(string.IsNullOrWhiteSpace(_imageUrl) || _isUploading)" @onclick="InsertImageAsync">Insert</button>
                </div>
            }
            else if (_activeDialog == EditorDialog.Video)
            {
                <div class="cloudeditor-dialogbody">
                    <label class="cloudeditor-field">
                        <span>Video URL</span>
                        <input type="text" placeholder="YouTube, Vimeo or direct video file URL" @bind="_videoUrl" @bind:event="oninput" />
                    </label>
                    <div class="cloudeditor-hint">Supports YouTube and Vimeo links, and direct .mp4 / .webm / .ogg files.</div>

                    @if (_dialogError is not null)
                    {
                        <div class="cloudeditor-message _error">@_dialogError</div>
                    }
                </div>
                <div class="cloudeditor-dialogfoot">
                    <button type="button" class="cloudeditor-action _secondary" @onclick="CloseDialogAsync">Cancel</button>
                    <button type="button" class="cloudeditor-action" disabled="@string.IsNullOrWhiteSpace(_videoUrl)" @onclick="InsertVideoAsync">Insert</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private RenderFragment ToolbarButton(RenderFragment icon, string title, Func<Task> onClick, bool active = false, bool? disabled = null) =>
        @<button type="button"
                 class="cloudeditor-btn @(active ? "_active" : null)"
                 title="@title"
                 aria-label="@title"
                 disabled="@(disabled ?? _commandsDisabled)"
                 @onclick="onClick"
                 @onmousedown:preventDefault="true">
            @icon
        </button>;

    private RenderFragment ColorPopover(string command) =>
        @<div class="cloudeditor-popover" @onmousedown:preventDefault="true">
            <div class="cloudeditor-swatches">
                @foreach (string color in ColorPalette)
                {
                    <button type="button" class="cloudeditor-swatch" style="background:@color" title="@color"
                            @onclick="() => ApplyColorAsync(command, color)" @onmousedown:preventDefault="true"></button>
                }
            </div>
            <div class="cloudeditor-popoverrow">
                <input type="color" value="#000000" @onchange="@(args => ApplyColorAsync(command, args.Value?.ToString() ?? "#000000"))" title="Custom color" />
                <button type="button" class="cloudeditor-action _secondary" @onclick="() => ClearColorAsync(command)">Clear</button>
            </div>
        </div>;
}
