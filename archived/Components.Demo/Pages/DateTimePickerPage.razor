@page "/datetimepicker"

<PageTitle>Date &amp; Time Picker — Cloud Components Demo</PageTitle>

<div class="page-header">
    <h1>Date &amp; Time Picker</h1>
    <p>
        <code>DateTimePicker</code> is an inline calendar and time picker.
        The <code>Mode</code> parameter controls whether the user can pick a date, a time, or both.
    </p>
</div>

<!-- ── Mode switcher ─────────────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Date &amp; Time (combined)</h2>
    <p class="card-subtitle"><code>Mode="DateTimePickerMode.DateAndTime"</code></p>

    <DateTimePicker Mode="DateTimePickerMode.DateAndTime" />
</div>

<div class="card">
    <h2 class="card-title">Date only</h2>
    <p class="card-subtitle"><code>Mode="DateTimePickerMode.Date"</code></p>

    <DateTimePicker Mode="DateTimePickerMode.Date" />
</div>

<div class="card">
    <h2 class="card-title">Time only</h2>
    <p class="card-subtitle"><code>Mode="DateTimePickerMode.Time"</code></p>

    <DateTimePicker Mode="DateTimePickerMode.Time" />
</div>

<!-- ── Runtime mode switch ───────────────────────────────────────────────── -->
<div class="card">
    <h2 class="card-title">Runtime mode switching</h2>
    <p class="card-subtitle">Change the mode at runtime using the selector below.</p>

    <div class="toolbar">
        <label>Mode</label>
        <select class="input" @bind="_mode">
            <option value="@DateTimePickerMode.DateAndTime">DateAndTime</option>
            <option value="@DateTimePickerMode.Date">Date</option>
            <option value="@DateTimePickerMode.Time">Time</option>
        </select>
    </div>

    <DateTimePicker Mode="@_mode" />
</div>

@code {
    private DateTimePickerMode _mode = DateTimePickerMode.DateAndTime;
}
