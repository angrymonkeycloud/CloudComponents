@page "/reverse-geocode"
@using System.Text.Json
@inject IOptions<AzureMapsOptions> Options
@inject AzureMapsConfigurationService ConfigService

<PageTitle>CloudMaps — Reverse Geocode Address</PageTitle>

<div class="page-header">
    <h1>Reverse Geocoding with Address Lookup</h1>
    <p>
        Pan the map to position the center pin over a location, then click <strong>Get Address</strong>
        to perform reverse geocoding and retrieve the address, country, and administrative subdivisions via Cloud Geography.
    </p>
</div>

<DemoResultCodeTabs>
    <ResultContent>
        <div class="card">
    <h2 class="card-title">Interactive Map</h2>
    <div class="grid-host" style="height: 500px;">
        <AzureMap Height="500px"
                  Width="100%"
                  SubscriptionKey="@GetSubscriptionKey()"
                  InitialView="@_initialView"
                  Style="MapStyle.Road"
                  AddMarkerTrigger="MarkerAddTrigger.CenterPin"
                  ShowCurrentLocationButton="true"
                  OnCenterPinChanged="HandleCenterPinChanged"
                  OnMapReady="HandleMapReady"
                  @ref="_map" />
    </div>

    <div class="toolbar" style="margin-top: 1rem; display: flex; gap: 12px; align-items: center;">
        <button class="primary" @onclick="ResetToEmberAndDrops">Reset to Ember &amp; Drops</button>
        <button @onclick="FetchAddressManually" disabled="@_isLoading" title="Manually fetch address for current center pin location">
            🔄 Get Address Now
        </button>
        <span class="badge">Status: @_status</span>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div style="margin-top: 12px; background: #fef3f3; border: 1px solid #ffcdd2; border-radius: 6px; padding: 12px; color: #c62828; font-size: 13px;">
            <strong>⚠️ Error:</strong> @_errorMessage
        </div>
    }
</div>

@if (_currentAddress != null)
{
    <div class="card">
        <h2 class="card-title">📍 Full Address</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">

            <!-- Coordinates -->
            <div>
                <h3 style="margin: 0 0 10px 0; font-size: 13px; font-weight: 600; color: #0078d4; text-transform: uppercase; letter-spacing: .04em;">Coordinates</h3>
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 13px; font-family: 'Courier New', monospace;">
                    <div><strong>Lat:</strong> @_currentAddress.Latitude.ToString("F6")</div>
                    <div><strong>Lng:</strong> @_currentAddress.Longitude.ToString("F6")</div>
                    <div style="margin-top: 8px; color: #888; font-size: 11px;">@_currentAddress.ResolvedAt.ToString("HH:mm:ss")</div>
                </div>
            </div>

            <!-- Street-level address -->
            <div>
                <h3 style="margin: 0 0 10px 0; font-size: 13px; font-weight: 600; color: #0078d4; text-transform: uppercase; letter-spacing: .04em;">Street Address</h3>
                <div style="background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; font-size: 13px; display: flex; flex-direction: column; gap: 4px;">
                    @if (!string.IsNullOrEmpty(_currentAddress.Street))
                    {
                        <div><strong>Street:</strong> @_currentAddress.Street</div>
                    }
                    @if (!string.IsNullOrEmpty(_currentAddress.Neighborhood))
                    {
                        <div><strong>Neighborhood:</strong> @_currentAddress.Neighborhood</div>
                    }
                    @if (!string.IsNullOrEmpty(_currentAddress.City))
                    {
                        <div><strong>City:</strong> @_currentAddress.City</div>
                    }
                    @if (!string.IsNullOrEmpty(_currentAddress.County))
                    {
                        <div><strong>County:</strong> @_currentAddress.County</div>
                    }
                    @if (!string.IsNullOrEmpty(_currentAddress.PostalCode))
                    {
                        <div><strong>Postal Code:</strong> @_currentAddress.PostalCode</div>
                    }
                    @if (string.IsNullOrEmpty(_currentAddress.Street) &&
                         string.IsNullOrEmpty(_currentAddress.City) &&
                         string.IsNullOrEmpty(_currentAddress.County))
                    {
                        <span style="color: #999; font-style: italic;">No street-level data for this location</span>
                    }
                </div>
            </div>
        </div>

        <!-- Country -->
        @if (_country != null)
        {
            <div style="margin-top: 20px;">
                <h3 style="margin: 0 0 10px 0; font-size: 13px; font-weight: 600; color: #0078d4; text-transform: uppercase; letter-spacing: .04em;">🌍 Country</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px;">
                    <div style="background: #e3f2fd; border-left: 3px solid #0078d4; padding: 10px 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #666; margin-bottom: 2px;">Name</div>
                        <div style="font-weight: 600; color: #0078d4;">@_country.Name</div>
                    </div>
                    <div style="background: #e3f2fd; border-left: 3px solid #0078d4; padding: 10px 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #666; margin-bottom: 2px;">ISO Code</div>
                        <div style="font-weight: 600; color: #0078d4;">@_country.Code / @_country.ThreeLettersCode</div>
                    </div>
                    @if (_country.CallingCode > 0)
                    {
                        <div style="background: #e3f2fd; border-left: 3px solid #0078d4; padding: 10px 12px; border-radius: 4px;">
                            <div style="font-size: 11px; color: #666; margin-bottom: 2px;">Calling Code</div>
                            <div style="font-weight: 600; color: #0078d4;">+@_country.CallingCode</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_country.Capital))
                    {
                        <div style="background: #e3f2fd; border-left: 3px solid #0078d4; padding: 10px 12px; border-radius: 4px;">
                            <div style="font-size: 11px; color: #666; margin-bottom: 2px;">Capital</div>
                            <div style="font-weight: 600; color: #0078d4;">@_country.Capital</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- DEBUG: Show all fields -->
        <div style="margin-top: 20px; padding: 12px; background: #f0f0f0; border: 1px solid #ccc; border-radius: 6px; font-size: 11px; font-family: 'Courier New', monospace; max-height: 400px; overflow: auto;">
            <strong style="display: block; margin-bottom: 8px;">🔍 Debug - Raw Azure Fields:</strong>
            @if (_rawAzureFields.Any())
            {
                <div style="background: #fff; padding: 8px; border-radius: 3px; margin-bottom: 10px;">
                    @foreach (var field in _rawAzureFields.OrderBy(x => x.Key))
                    {
                        <div style="margin-bottom: 3px;"><strong>@field.Key:</strong> '@field.Value'</div>
                    }
                </div>
            }

            <strong style="display: block; margin: 10px 0 8px 0;">🗺️ Cloud Geography Resolution:</strong>
            <div>Country: @(_country?.Name ?? "N/A") (@(_country?.Code ?? "N/A"))</div>

            <strong style="display: block; margin: 10px 0 8px 0;">📍 Subdivision Matching Results:</strong>
            @if (_subdivisionEntries.Any())
            {
                @foreach (var entry in _subdivisionEntries)
                {
                    <div style="background: #fff; padding: 8px; border-radius: 3px; margin-bottom: 8px; border-left: 3px solid @(entry.GeoMatch != null ? "#4caf50" : "#ff9800");">
                        <div><strong>@entry.Label</strong></div>
                        <div style="margin-left: 10px; margin-top: 4px;">
                            <div>Azure: '@entry.AzureName' @(string.IsNullOrEmpty(entry.AzureCode) ? "" : $"(Code: {entry.AzureCode})")</div>
                            <div style="color: @(entry.GeoMatch != null ? "#4caf50" : "#ff9800"); font-weight: 600;">
                                @if (entry.GeoMatch != null)
                                {
                                    <span>✓ MATCH: @entry.GeoMatch.Name (@entry.GeoMatch.Code)</span>
                                }
                                else
                                {
                                    <span>✗ NO MATCH</span>
                                }
                            </div>
                            @if (entry.Children?.Any() == true)
                            {
                                <div style="margin-top: 4px; font-size: 10px; color: #666;">Children: @string.Join(", ", entry.Children.Select(c => $"{c.Name} ({c.Code})"))</div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="color: #999;">No subdivisions matched</div>
            }
        </div>

        <!-- Subdivision entries with Match / No Match badges -->
        @if (_subdivisionEntries.Count > 0)
        {
            <div style="margin-top: 20px;">
                <h3 style="margin: 0 0 10px 0; font-size: 13px; font-weight: 600; color: #107c10; text-transform: uppercase; letter-spacing: .04em;">🗺️ Administrative Subdivisions (@_subdivisionEntries.Count)</h3>
                <div style="display: flex; flex-direction: column; gap: 14px;">
                    @foreach (var entry in _subdivisionEntries)
                    {
                        var isMatch = entry.GeoMatch is not null;
                        var badgeColor = isMatch ? "#107c10" : "#e65100";
                        var badgeBg = isMatch ? "#e8f5e9" : "#fff3e0";
                        var badgeBorder = isMatch ? "#a5d6a7" : "#ffcc80";
                        var borderColor = isMatch ? "#107c10" : "#e65100";
                        var bgColor = isMatch ? "#f0faf0" : "#fffde7";
                        var geoMatch = entry.GeoMatch;

                        <div style="border: 1px solid @borderColor; border-radius: 6px; overflow: hidden;">
                            <!-- Header row: label + Azure name + match badge -->
                            <div style="background: @bgColor; padding: 10px 14px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                                <span style="font-size: 11px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: .05em; min-width: 130px;">@entry.Label</span>
                                <span style="font-size: 13px; font-weight: 600; color: #222;">@entry.AzureName</span>
                                @if (!string.IsNullOrEmpty(entry.AzureCode))
                                {
                                    <span style="font-size: 12px; color: #666;">(@entry.AzureCode)</span>
                                }
                                <span style="margin-left: auto; background: @badgeBg; border: 1px solid @badgeBorder; color: @badgeColor; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px;">
                                    @(isMatch ? "Match" : "No Match")
                                </span>
                            </div>

                            @if (geoMatch is not null)
                            {
                                <!-- Cloud Geography details -->
                                <div style="padding: 10px 14px; display: flex; flex-wrap: wrap; gap: 10px; border-top: 1px solid #c8e6c9;">
                                    <div style="min-width: 120px;">
                                        <div style="font-size: 11px; color: #888;">CG Name</div>
                                        <div style="font-size: 13px; font-weight: 500;">@geoMatch.Name</div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(geoMatch.LocalName) && geoMatch.LocalName != geoMatch.Name)
                                    {
                                        <div style="min-width: 120px;">
                                            <div style="font-size: 11px; color: #888;">Local Name</div>
                                            <div style="font-size: 13px; font-weight: 500;">@geoMatch.LocalName</div>
                                        </div>
                                    }
                                    <div style="min-width: 80px;">
                                        <div style="font-size: 11px; color: #888;">Code</div>
                                        <div style="font-size: 13px; font-weight: 500;">@geoMatch.Code</div>
                                    </div>
                                    <div style="min-width: 80px;">
                                        <div style="font-size: 11px; color: #888;">Type</div>
                                        <div style="font-size: 13px; font-weight: 500;">@geoMatch.Type</div>
                                    </div>
                                </div>

                                @if (entry.Children is { Count: > 0 })
                                {
                                    <div style="padding: 8px 14px 10px; border-top: 1px solid #e8f5e9; background: #fafffe;">
                                        <div style="font-size: 11px; color: #666; margin-bottom: 6px; font-weight: 600;">Sub-regions (@entry.Children.Count)</div>
                                        <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                                            @foreach (var child in entry.Children)
                                            {
                                                <span style="background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 4px; padding: 2px 7px; font-size: 12px; color: #2e7d32;">
                                                    @child.Code — @child.Name
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        }

    </div>
}
else if (_isLoading)
{
    <div class="card">
        <div style="text-align: center; padding: 40px; color: #999;">
            ⏳ Loading address information...
        </div>
    </div>
}
else
{
    <div class="card">
        <div style="text-align: center; padding: 40px; color: #999;">
            Pan the map to position the center pin, then click <strong>Get Address</strong>.
        </div>
    </div>
}
    </ResultContent>

    <CodeContent>
        <div class="card">
            <h2 class="card-title">How to implement in your app</h2>
            <p style="font-size: 13px; color: #666; margin-top: 0;">
                Use <code>MarkerAddTrigger.CenterPin</code> to keep a pin fixed at the map center, read its
                coordinate from <code>OnCenterPinChanged</code>, and call <code>ReverseGeocodeAsync</code> to resolve
                an address. Combine the result's country/subdivision codes with <code>CloudGeographyClient</code> for
                richer administrative data.
            </p>
            <pre class="code-snippet"><code>@_usageSnippet</code></pre>
        </div>
    </CodeContent>
</DemoResultCodeTabs>

@code {
    private AzureMap? _map;
    private readonly InitialMapView _initialView = new(33.846544, 35.534194, 13);

    private readonly string _usageSnippet = """
<AzureMap AddMarkerTrigger="MarkerAddTrigger.CenterPin"
          OnCenterPinChanged="HandleCenterPinChanged"
          @ref="_map" />

@code {
    private AzureMap? _map;

    private async Task HandleCenterPinChanged(Coordinate coordinate)
    {
        var address = await _map!.ReverseGeocodeAsync(coordinate.Latitude, coordinate.Longitude);
        if (address is null)
            return;

        // Optionally cross-reference the country/subdivision codes with CloudGeographyClient
        // for richer administrative data (name, capital, calling code, sub-regions, ...).
        var geoClient = new CloudGeographyClient();
        var country = geoClient.Countries.Get(address.CountryCode);
    }
}
""";

    private AddressInfo? _currentAddress;
    private Country? _country;
    private List<SubdivisionEntry> _subdivisionEntries = [];
    private Dictionary<string, string> _rawAzureFields = new();
    private bool _isLoading;
    private string _status = "Ready";
    private string? _errorMessage;
    private MapCoordinate? _lastRequestedCoord;

    private async Task HandleMapReady()
    {
        // Map is ready
    }

    private Task HandleCenterPinChanged(MapCoordinate coord)
    {
        // Just record the latest coordinate — address is only fetched when the user clicks the button
        _lastRequestedCoord = coord;
        return Task.CompletedTask;
    }

    private async Task FetchAddressAsync(MapCoordinate coord, CancellationToken cancellationToken = default)
    {
        _isLoading = true;
        _status = "Fetching address...";
        _errorMessage = null;
        _currentAddress = null;
        _country = null;
        _subdivisionEntries = [];
        StateHasChanged();

        try
        {
            if (_map == null)
            {
                _errorMessage = "Map component not initialized";
                _status = "Error";
                return;
            }

            var subscriptionKey = GetSubscriptionKey();
            if (string.IsNullOrEmpty(subscriptionKey) || subscriptionKey.Contains("placeholder"))
            {
                _errorMessage = "Azure Maps subscription key not configured. Please configure it in settings.";
                _status = "Error";
                return;
            }

            var url = $"https://atlas.microsoft.com/search/address/reverse/json?api-version=1.0&subscription-key={System.Net.WebUtility.UrlEncode(subscriptionKey)}&query={coord.Latitude},{coord.Longitude}";

            using var client = new System.Net.Http.HttpClient();
            var response = await client.GetAsync(url, cancellationToken);

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Azure Maps API error: {response.StatusCode}. Make sure your subscription key is valid.";
                _status = "API Error";
                return;
            }

            var content = await response.Content.ReadAsStringAsync(cancellationToken);
            var jsonDoc = System.Text.Json.JsonDocument.Parse(content);
            var root = jsonDoc.RootElement;

            if (!root.TryGetProperty("addresses", out var addressesArray) || addressesArray.GetArrayLength() == 0)
            {
                _errorMessage = "No address found for this location. Try a different area.";
                _status = "No results";
                return;
            }

            var firstResult = addressesArray[0];

            string Str(JsonElement parent, string key)
                => parent.TryGetProperty(key, out var el) && el.ValueKind == JsonValueKind.String
                    ? el.GetString() ?? string.Empty
                    : string.Empty;

            if (!firstResult.TryGetProperty("address", out var addr))
            {
                _errorMessage = "Azure Maps returned a result but with no address data.";
                _status = "No address data";
                return;
            }

            // Capture all raw Azure fields for debugging
            _rawAzureFields = new();
            foreach (var prop in new[] { 
                "streetNumber", "streetName", "freeformAddress", "neighbourhood", "postalCode", 
                "municipality", "municipalitySubdivision", "countrySubdivision", "countrySubdivisionCode",
                "countrySecondarySubdivision", "countryTertiarySubdivision", "country", "countryCode" })
            {
                var value = Str(addr, prop);
                if (!string.IsNullOrEmpty(value))
                    _rawAzureFields[prop] = value;
            }

            // Build the full address from all Azure Maps fields
            var streetNumber = Str(addr, "streetNumber");
            var streetName = Str(addr, "streetName");
            var street = streetNumber.Length > 0 && streetName.Length > 0
                ? $"{streetNumber} {streetName}"
                : streetName.Length > 0 ? streetName
                : Str(addr, "freeformAddress");

            _currentAddress = new AddressInfo
            {
                Latitude = coord.Latitude,
                Longitude = coord.Longitude,
                Street = street,
                Neighborhood = Str(addr, "neighbourhood"),
                PostalCode = Str(addr, "postalCode"),
                City = Str(addr, "municipality"),
                County = Str(addr, "municipalitySubdivision"),
                District = Str(addr, "countrySubdivision"),
                CountryTertiarySubdivision = Str(addr, "countryTertiarySubdivision"),
                CountrySecondarySubdivision = Str(addr, "countrySecondarySubdivision"),
                Subdivision = Str(addr, "countrySubdivision"),
                SubdivisionCode = Str(addr, "countrySubdivisionCode"),
                CountryRegion = Str(addr, "country"),
                CountryCode = Str(addr, "countryCode")
            };

            // Cloud Geography: resolve country by code (from Azure) — avoids coordinate lookup failure in WASM
            var geoClient = new CloudGeographyClient();
            var countryCode = Str(addr, "countryCode");
            var country = !string.IsNullOrEmpty(countryCode)
                ? geoClient.Countries.Get(countryCode)
                : await geoClient.Countries.GetByCoordinates(
                    new AngryMonkey.Cloud.Geography.Coordinate(coord.Latitude, coord.Longitude));

            if (country != null)
            {
                _country = country;
                _currentAddress.CountryRegion = country.Name;
                _currentAddress.CountryCode = country.Code;

                // Build subdivision entries for each level Azure Maps reported, using Find for matching
                var entries = new List<SubdivisionEntry>();

                void AddEntry(string label, string azureName, string? azureCode, string? parentCode = null)
                {
                    Subdivision? geoMatch = null;
                    List<Subdivision>? children = null;

                    if (!string.IsNullOrEmpty(azureName) || !string.IsNullOrEmpty(azureCode))
                    {
                        // 1. Try Find by name (most reliable when name matches exactly)
                        if (!string.IsNullOrEmpty(azureName))
                            geoMatch = geoClient.Subdivisions.Find(country.Code, azureName);

                        // 2. Try Get by raw code, then by prefixed code (LB-JL vs JL)
                        if (geoMatch == null && !string.IsNullOrEmpty(azureCode))
                        {
                            geoMatch = geoClient.Subdivisions.Get(country.Code, azureCode)
                                    ?? geoClient.Subdivisions.Get(country.Code, $"{country.Code}-{azureCode}");
                        }

                        // 3. If still no match, try Search with optional parent scope
                        if (geoMatch == null && !string.IsNullOrEmpty(azureName))
                        {
                            var searchResult = geoClient.Subdivisions.Search(new()
                            {
                                CountryCode = country.Code,
                                Query = azureName,
                                ParentSubdivisionCode = parentCode
                            });
                            geoMatch = searchResult?.Matches?.FirstOrDefault()?.Subdivision;
                        }

                        if (geoMatch != null)
                            children = geoClient.Subdivisions.GetChildren(country.Code, geoMatch.Code);
                    }

                    entries.Add(new SubdivisionEntry
                    {
                        Label = label,
                        AzureName = azureName ?? string.Empty,
                        AzureCode = azureCode,
                        GeoMatch = geoMatch,
                        Children = children
                    });
                }

                // Get the primary subdivision for parent context
                var primarySubdiv = geoClient.Subdivisions.Find(country.Code, _currentAddress.Subdivision ?? "");

                AddEntry("State / Province", _currentAddress.Subdivision, _currentAddress.SubdivisionCode);
                AddEntry("Secondary Division", _currentAddress.CountrySecondarySubdivision, null, primarySubdiv?.Code);
                AddEntry("Tertiary Division", _currentAddress.CountryTertiarySubdivision, null, primarySubdiv?.Code);

                // Filter out empty entries for display
                _subdivisionEntries = entries.Where(e => !string.IsNullOrEmpty(e.AzureName)).ToList();

                var topMatch = entries.FirstOrDefault(e => e.GeoMatch is not null);
                _status = topMatch != null
                    ? $"✓ {topMatch.GeoMatch!.Name}, {country.Name}"
                    : $"✓ Address retrieved ({country.Name})";
            }
            else
            {
                _status = "✓ Address retrieved";
            }
        }
        catch (OperationCanceledException)
        {
            // Request cancelled — don't update error message
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _errorMessage = $"Network error: {ex.Message}. Check your internet connection.";
            _status = "Network Error";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error retrieving address: {ex.Message}";
            _status = "Error";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ResetToEmberAndDrops()
    {
        if (_map != null)
            await _map.SetCenterAsync(33.846544, 35.534194, 13);
    }

    private async Task FetchAddressManually()
    {
        if (_map == null)
        {
            _errorMessage = "Map not initialized";
            _status = "Error";
            StateHasChanged();
            return;
        }

        if (_lastRequestedCoord.HasValue)
        {
            await FetchAddressAsync(_lastRequestedCoord.Value);
        }
        else
        {
            _errorMessage = "No coordinates available. Pan the map first.";
            _status = "Error";
            StateHasChanged();
        }
    }

    private string GetSubscriptionKey()
    {
        var configured = ConfigService.GetSubscriptionKey();
        if (!string.IsNullOrEmpty(configured))
            return configured;

        return Options?.Value?.SubscriptionKey ?? string.Empty;
    }
}



