@using CloudComponents.Maps.Demo.Services
@inherits LayoutComponentBase
@inject AzureMapsConfigurationService ConfigService

<ConfigurationModal IsVisible="@ShowConfigurationModal" 
                    OnClose="@HideConfigurationModal"
                    OnConfigurationSaved="@HandleConfigurationSaved" />

<div class="layout">
    <NavMenu OnSettingsClick="ShowConfiguration" />
    <main class="layout-main">
        <div class="layout-content">
            @Body
        </div>
    </main>
</div>

@code {
    private bool ShowConfigurationModal = false;

    private void ShowConfiguration()
    {
        ShowConfigurationModal = true;
    }

    private async Task HideConfigurationModal()
    {
        ShowConfigurationModal = false;
        StateHasChanged();
    }

    private async Task HandleConfigurationSaved(string key)
    {
        ShowConfigurationModal = false;
        StateHasChanged();
    }
}
