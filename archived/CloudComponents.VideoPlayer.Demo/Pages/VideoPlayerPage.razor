@page "/player"

<PageTitle>CloudVideoPlayer Demo — Player</PageTitle>

<div class="page-header">
    <h1>Video Player</h1>
    <p>Standard MP4 playback with controls, settings menu, volume, fullscreen, and progress bar.</p>
</div>

<div class="card">
    <h2 class="card-title">Oceans (MP4)</h2>
    <p class="card-subtitle">
        Open-source sample video — <code>@Metadata.VideoUrl</code>
    </p>
    <div class="player-wrapper">
        <VideoPlayer Metadata="Metadata" />
    </div>
</div>

@code {
    private VideoPlayerMetadata Metadata = new()
    {
        Title = "Oceans",
        VideoUrl = "https://vjs.zencdn.net/v/oceans.mp4",
        EnableControls = true,
        ShowProgressBar = true,
        ShowSettings = true,
        Volume = 0.8
    };
}
